<div class="w-full max-w-md mx-auto flex flex-col items-center gap-10" style="margin: 0;">
  <header class="text-center space-y-2">
    <h1 class="font-headline font-extrabold text-2xl tracking-tight text-on-surface">我的 SCASH 收款地址</h1>
    <p class="text-on-surface-variant text-sm font-medium tracking-wide">扫描二维码或向下方地址发送资产</p>
  </header>

  <div class="relative w-full aspect-square max-w-[320px]">
    <div class="absolute inset-0 bg-primary-container/20 blur-[80px] rounded-full scale-110"></div>
    <div class="relative z-10 bg-surface-container-lowest p-8 rounded-lg shadow-[0px_12px_48px_rgba(145,40,173,0.12)] flex items-center justify-center overflow-hidden border border-white/50">
      <div id="qrcode" class="w-full aspect-square flex items-center justify-center">
        <div class="text-on-surface-variant text-sm"><span class="spinner"></span>加载中…</div>
      </div>
    </div>
  </div>

  <div class="w-full space-y-4">
    <div class="bg-surface-container-low px-6 py-5 rounded-lg flex flex-col items-center gap-3">
      <span class="text-on-surface-variant text-[10px] font-bold uppercase tracking-widest font-headline">收款地址</span>
      <div class="w-full text-center">
        <p id="myAddress" class="font-mono text-sm leading-relaxed break-all text-on-surface selection:bg-primary-container selection:text-on-primary-container">-</p>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <button id="btnCopy" class="flex items-center justify-center gap-2 bg-gradient-to-br from-primary to-primary-container text-white font-bold py-4 rounded-full shadow-lg shadow-primary/20 active:scale-95 transition-all duration-200">
        <span class="material-symbols-outlined text-lg">content_copy</span>
        <span>复制地址</span>
      </button>
      <button id="btnShare" class="flex items-center justify-center gap-2 bg-surface-container-high text-primary font-bold py-4 rounded-full active:scale-95 transition-all duration-200">
        <span class="material-symbols-outlined text-lg">share</span>
        <span>分享地址</span>
      </button>
    </div>

    <div id="copyTip" class="text-center text-primary font-medium text-sm mt-4 h-5 opacity-0 transition-opacity duration-300">已复制到剪贴板</div>
  </div>

  <footer class="flex items-center gap-2 px-6 py-3 bg-error/5 rounded-full">
    <span class="material-symbols-outlined text-error text-base" style="font-variation-settings: 'FILL' 1;">info</span>
    <span class="text-error font-bold text-xs tracking-wide">仅支持 SCASH 网络资产</span>
  </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
  let currentAddress = '';

  function showTip(msg) {
    var tip = document.getElementById('copyTip');
    tip.textContent = msg;
    tip.style.opacity = '1';
    setTimeout(function () { tip.style.opacity = '0'; }, 2000);
  }

  async function loadAddress() {
    try {
      var home = await window.SCASH.request('/api/wallet/home');
      var addr = home.address;
      if (!addr) {
        document.getElementById('myAddress').textContent = '未创建钱包';
        document.getElementById('qrcode').innerHTML = '<div class="text-on-surface-variant text-sm">请先创建或导入钱包</div>';
        return;
      }
      
      currentAddress = addr;
      document.getElementById('myAddress').textContent = addr;
      
      var qrEl = document.getElementById('qrcode');
      qrEl.innerHTML = '';
      
      try {
        var uri =  addr;
        
        // 使用 qrcodejs 这个库（它保证能在所有浏览器下暴露全局 QRCode 对象）
        new QRCode(qrEl, {
          text: uri,
          width: 240,
          height: 240,
          colorDark: '#9128ad',
          colorLight: '#ffffff',
          correctLevel: QRCode.CorrectLevel.L
        });

        // 保证库画出的图填充满盒子
        setTimeout(() => {
          var imgs = qrEl.getElementsByTagName('img');
          if (imgs.length > 0) {
            imgs[0].style.width = '100%';
            imgs[0].style.height = '100%';
            imgs[0].style.display = 'block';
          }
          var canvas = qrEl.getElementsByTagName('canvas');
          if (canvas.length > 0) {
            canvas[0].style.width = '100%';
            canvas[0].style.height = '100%';
          }
        }, 50);

      } catch (qrErr) {
        console.error('QR Generate Error:', qrErr);
        qrEl.innerHTML = '<div class="text-error text-sm">二维码生成失败</div>';
      }
    } catch (e) {
      console.error('Load Address Error:', e);
      document.getElementById('myAddress').textContent = '获取失败';
      document.getElementById('qrcode').innerHTML = '<div class="text-error text-sm">加载失败</div>';
    }
  }

  document.getElementById('btnCopy').addEventListener('click', function () {
    if (!currentAddress) return;

    var btn = this;
    var icon = btn.querySelector('.material-symbols-outlined');
    var text = btn.querySelector('span:last-child');
    var originalIcon = icon.textContent;
    var originalText = text.textContent;

    var doCopy = function() {
      icon.textContent = 'check';
      text.textContent = '已复制';
      btn.classList.remove('from-primary', 'to-primary-container');
      btn.classList.add('bg-tertiary');

      setTimeout(function() {
        icon.textContent = originalIcon;
        text.textContent = originalText;
        btn.classList.remove('bg-tertiary');
        btn.classList.add('from-primary', 'to-primary-container');
      }, 1500);
    };

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(currentAddress).then(function() {
        doCopy();
        showTip('已复制到剪贴板');
      }).catch(function() {
        showTip('复制失败，请手动长按复制');
      });
    } else {
      var textArea = document.createElement('textarea');
      textArea.value = currentAddress;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        doCopy();
        showTip('已复制到剪贴板');
      } catch (err) {
        showTip('复制失败，请手动长按复制');
      }
      document.body.removeChild(textArea);
    }
  });

  document.getElementById('btnShare').addEventListener('click', function () {
    if (!currentAddress) return;
    
    var tg = window.SCASH && window.SCASH.TG;
    var shareText = '这是我的 SCASH 收款地址：\n\n' + currentAddress;
    
    if (tg && tg.openTelegramLink) {
      var shareIntent = 'https://t.me/share/url?url=' + encodeURIComponent(currentAddress) + '&text=' + encodeURIComponent(shareText);
      tg.openTelegramLink(shareIntent);
    } else if (navigator.share) {
      navigator.share({
        title: '我的 SCASH 收款地址',
        text: shareText
      }).catch(function() {
        showTip('分享被取消');
      });
    } else {
      showTip('当前环境不支持直接分享，请复制地址');
    }
  });

  loadAddress();
</script>