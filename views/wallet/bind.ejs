<div class="card">
  <div class="info">绑定一个已有的 Scash 地址作为观察钱包。观察钱包只能接收，无法签名发送，适合只收不发的场景。</div>

  <div class="label">Scash 地址</div>
  <input id="address" type="text" placeholder="scash1..." autocomplete="off" />

  <button id="submitBtn" class="btn btn-brand" style="margin-top:16px;">绑定观察钱包</button>
  <div id="errorMsg" class="error" style="display:none; margin-top:10px;"></div>
</div>

<script>
  function setLoading(on) {
    var btn = document.getElementById('submitBtn');
    if (on) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>绑定中…'; }
    else { btn.disabled = false; btn.textContent = '绑定观察钱包'; }
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = msg; el.style.display = 'block';
  }

  document.getElementById('submitBtn').addEventListener('click', async function () {
    var addr = document.getElementById('address').value.trim();
    showError('');
    if (!addr || addr.length < 10) { showError('请输入有效的 Scash 地址'); return; }
    setLoading(true);
    try {
      await window.SCASH.request('/api/wallet/bind', {
        method: 'POST',
        body: JSON.stringify({ address: addr }),
      });
      if (window.SCASH.TG) window.SCASH.TG.close();
    } catch (e) {
      showError(e.message);
      setLoading(false);
    }
  });
</script>