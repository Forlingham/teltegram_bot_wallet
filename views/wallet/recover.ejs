<div class="card">
  <div class="info">从云端下载加密备份后，在本地输入密码解密恢复助记词。后端不接触明文助记词。</div>
  <button id="loadBtn" class="btn btn-brand">读取云端备份</button>

  <div id="backupSection" style="display:none; margin-top:16px;">
    <div class="label">备份数据（密文）</div>
    <pre id="backupData">-</pre>
    <div class="label" style="margin-top:12px;">输入密码解密</div>
    <input id="password" type="password" placeholder="输入密码解密" autocomplete="off" />
    <button id="decryptBtn" class="btn btn-brand" style="margin-top:8px;">解密并显示</button>
    <div id="mnemonicResult" style="margin-top:12px; font-size:13px; color:var(--brand); word-break:break-all; font-family:ui-monospace;"></div>
  </div>

  <div id="errorMsg" style="color:#c0392b;font-size:13px;margin-top:10px;display:none;"></div>
</div>

<script>
  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = msg; el.style.display = 'block';
  }

  async function decryptMnemonic(salt, iv, ciphertext, password) {
    function fromHex(str) { return new Uint8Array(str.match(/.{2}/g).map(function (b) { return parseInt(b, 16); })); }
    var saltBytes = fromHex(salt);
    var ivBytes = fromHex(iv);
    var ctBytes = fromHex(ciphertext);
    var keyMaterial = await crypto.subtle.importKey('raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveBits']);
    var key = await crypto.subtle.deriveBits({ name: 'PBKDF2', salt: saltBytes, iterations: 100000, hash: 'SHA-256' }, keyMaterial, 256);
    var aesKey = await crypto.subtle.importKey('raw', key, 'AES-GCM', false, ['decrypt']);
    var pt = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: ivBytes, tagLength: 128 }, aesKey, ctBytes);
    return new TextDecoder().decode(pt);
  }

  document.getElementById('loadBtn').addEventListener('click', async function () {
    try {
      var data = await window.SCASH.request('/api/wallet/recover', { method: 'POST', body: '{}' });
      if (!data.backup) { showError('未找到云端备份，请先创建或备份钱包'); return; }
      document.getElementById('backupData').textContent = JSON.stringify(data.backup, null, 2);
      document.getElementById('backupSection').style.display = 'block';
    } catch (e) { showError(e.message); }
  });

  document.getElementById('decryptBtn').addEventListener('click', async function () {
    var pw = document.getElementById('password').value.trim();
    if (!pw) { showError('请输入密码'); return; }
    try {
      var data = await window.SCASH.request('/api/wallet/recover', { method: 'POST', body: '{}' });
      if (!data.backup) { showError('未找到云端备份'); return; }
      var cipherHex = data.backup.encryptedMnemonic || data.backup.ciphertext;
      var mnemonic = await decryptMnemonic(data.backup.salt, data.backup.iv, cipherHex, pw);
      document.getElementById('mnemonicResult').textContent = mnemonic;
    } catch (e) { showError('解密失败：' + e.message); }
  });
</script>
