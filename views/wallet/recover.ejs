<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
      body { margin: 0; font-family: "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif; background: #f6f8f4; color: #1f2a1f; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 20px 16px 40px; }
      .card { background: #fff; border: 1px solid #d9e3d7; border-radius: 14px; padding: 18px; margin-bottom: 14px; }
      h1 { margin: 0 0 10px; }
      .sub { color: #5b665c; margin: 0 0 14px; }
      .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; word-break: break-all; background: #f4f7f2; border-radius: 10px; padding: 10px; }
      button { border: 0; background: #2f7a42; color: white; border-radius: 10px; padding: 10px 14px; font-weight: 600; cursor: pointer; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>恢复钱包</h1>
        <p class="sub">后端仅返回密文备份，解密恢复助记词必须在前端本地完成。</p>
      </div>

      <div class="card">
        <button id="loadBtn">读取云端备份</button>
        <h3>备份数据</h3>
        <pre id="result" class="mono">尚未读取</pre>
      </div>
    </div>

    <script>
      (function () {
        const enabled = new URL(window.location.href).searchParams.get('debug') === '1' ||
          localStorage.getItem('DEBUG_CONSOLE') === '1';
        if (!enabled) return;
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/eruda';
        script.onload = function () { window.eruda && window.eruda.init(); };
        document.head.appendChild(script);
      })();
    </script>
    <script>
      const SESSION_KEY = 'SCASH_SESSION_TOKEN';
      function token() { return localStorage.getItem(SESSION_KEY) || ''; }

      async function request(path, options = {}) {
        const res = await fetch(path, {
          ...options,
          headers: {
            'Content-Type': 'application/json',
            'x-session-token': token(),
            ...(options.headers || {}),
          },
        });
        const json = await res.json();
        if (!res.ok || !json.success) throw new Error((json.error && json.error.message) || '请求失败');
        return json.data;
      }

      document.getElementById('loadBtn').addEventListener('click', async () => {
        try {
          const data = await request('/api/wallet/recover', { method: 'POST', body: '{}' });
          document.getElementById('result').textContent = JSON.stringify(data, null, 2);
        } catch (e) {
          alert(e.message);
        }
      });
    </script>
  </body>
  </html>
