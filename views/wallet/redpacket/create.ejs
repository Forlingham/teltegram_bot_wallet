<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .signature-gradient { background: linear-gradient(135deg, #9128ad 0%, #e67aff 100%); }
  
  .type-btn.active { background: var(--surface-container-lowest); border-color: rgba(145, 40, 173, 0.2); box-shadow: 0px 8px 24px rgba(0,0,0,0.04); opacity: 1; }
  .type-btn.active .type-icon { color: var(--primary); }
  .type-btn.active .type-text { color: var(--on-surface); }
  
  .expire-btn.active { background: linear-gradient(135deg, #9128ad 0%, #e67aff 100%); color: var(--on-primary); border-color: transparent; }
  
  #coverList .cover-item.active { border-color: var(--primary); }
</style>


<main id="createForm" class=" space-y-4" style="margin: 0;">
  <section class="relative overflow-hidden p-4 rounded-lg bg-surface-container-low">
    <div class="absolute -right-8 -top-8 w-32 h-32 bg-primary/10 rounded-full blur-3xl"></div>
    <div class="relative z-10 flex justify-between items-center">
      <div>
        <span class="font-label text-[10px] font-semibold text-on-surface-variant uppercase tracking-wider mb-0.5 block">可用余额</span>
        <div class="flex items-baseline gap-1">
          <span id="availBalance" class="font-headline text-xl font-bold text-on-surface">-</span>
          <span class="font-label text-xs font-medium text-primary">SCASH</span>
        </div>
      </div>
      <div class="p-2.5 bg-surface-container-lowest rounded-full shadow-[0px_4px_16px_rgba(145,40,173,0.06)]">
        <span class="material-symbols-outlined text-primary text-xl" style="font-variation-settings: 'FILL' 1;">account_balance_wallet</span>
      </div>
    </div>
  </section>

  <section class="grid grid-cols-2 gap-3">
    <button class="type-btn active flex flex-col items-center justify-center p-3.5 rounded-lg bg-surface-container-lowest shadow-[0px_8px_24px_rgba(0,0,0,0.04)] border-2 border-primary/20 transition-all" data-type="RANDOM">
      <span class="type-icon material-symbols-outlined text-primary mb-1.5 text-2xl">casino</span>
      <span class="type-text font-label text-xs font-bold text-on-surface">拼手气红包</span>
    </button>
    <button class="type-btn flex flex-col items-center justify-center p-3.5 rounded-lg bg-surface-container-low border-2 border-transparent opacity-60 hover:opacity-80 transition-all" data-type="EQUAL">
      <span class="type-icon material-symbols-outlined text-on-surface-variant mb-1.5 text-2xl">equalizer</span>
      <span class="type-text font-label text-xs font-bold text-on-surface-variant">普通红包</span>
    </button>
  </section>

  <section class="space-y-3">
    <div class="p-4 rounded-lg bg-surface-container-lowest shadow-[0px_4px_16px_rgba(44,47,49,0.02)]">
      <div class="flex justify-between items-center mb-2">
        <label class="font-label text-xs font-bold text-on-surface-variant">总金额</label>
        <span class="font-label text-[10px] font-semibold text-primary uppercase">SCASH</span>
      </div>
      <div class="flex items-center gap-3 relative">
        <input id="totalAmount" class="w-full bg-transparent border-none focus:ring-0 p-0 font-headline text-3xl font-bold text-on-surface placeholder:text-surface-variant" placeholder="0.00" type="text" autocomplete="off" />
        <div id="fiatEstimate" class="absolute right-0 bottom-1 font-label text-xs text-on-surface-variant"></div>
      </div>
    </div>
    
    <div class="p-4 rounded-lg bg-surface-container-lowest shadow-[0px_4px_16px_rgba(44,47,49,0.02)]">
      <div class="flex justify-between items-center mb-2">
        <label class="font-label text-xs font-bold text-on-surface-variant">红包个数</label>
        <span class="font-label text-[10px] font-semibold text-on-surface-variant">个</span>
      </div>
      <div class="flex items-center gap-3">
        <input id="count" class="w-full bg-transparent border-none focus:ring-0 p-0 font-headline text-3xl font-bold text-on-surface placeholder:text-surface-variant" placeholder="0" type="number" autocomplete="off" min="1" />
      </div>
    </div>
  </section>

  <section class="space-y-3">
    <div class="flex flex-col gap-1 px-1">
      <span class="font-label text-[9px] font-extrabold uppercase tracking-widest text-on-surface-variant/70">红包设置</span>
    </div>
    
