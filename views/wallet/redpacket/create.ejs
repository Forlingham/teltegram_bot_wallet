        </div>
      </div>

      <div class="p-4 bg-surface-container-lowest mb-[1px]">
        <div class="flex items-center justify-between mb-3">
          <span class="font-label text-xs font-semibold text-on-surface">有效期</span>
          <span id="expireDisplay" class="font-label text-[10px] text-primary font-bold">24小时</span>
        </div>
