  document.getElementById('submitBtn').addEventListener('click', async function () {
    if (isSubmitting) return;

    var total = document.getElementById('totalAmount').value.trim();
    var count = document.getElementById('count').value.trim();
    var message = document.getElementById('message').value.trim();
    var blessMessage = message || '恭喜发财，大吉大利';
    showError('');

    try {
      await updateEstimate();
      var check = validateForm();
      if (!check.ok) {
        showError(check.message);
        return;
      }

      var expireSec = getSelectedExpireSeconds();
      var expireLabel = { 180: '3 分钟', 86400: '24 小时', 604800: '7 天', 31536000: '永久' }[expireSec] || (expireSec + ' 秒');

      document.getElementById('confirmTotal').textContent = check.total;
      document.getElementById('confirmType').textContent = selectedType === 'RANDOM' ? '拼手气红包 (Random)' : '普通红包 (Equal)';
      document.getElementById('confirmCount').textContent = check.countInt + ' 个';
      document.getElementById('confirmMessage').textContent = blessMessage;
      document.getElementById('confirmExpire').textContent = expireLabel;
      document.getElementById('confirmTotalNeed').textContent = (latestEstimateTotalSat ? satoshiToScashTrimmed(latestEstimateTotalSat) : satoshiToScashTrimmed(check.totalNeedSat)) + ' SCASH';

      var confirmed = await showConfirmModal();
      if (!confirmed) return;

      // 密码输入循环：允许重试（最多2次）
      var mnemonic = null;
      var pwRetries = 2;
      
      var pw = await showPasswordModal(null, async function(val) {
        try {
          mnemonic = await decryptMnemonic(val);
          return true; // 验证成功，关闭弹窗
        } catch (pwErr) {
          pwRetries--;
          if (pwRetries <= 0) {
            showError('密码多次错误，请确认后重试');
            return 'TOO_MANY_ERRORS'; // 关闭弹窗并中断
          }
          return '密码错误，您还有 ' + pwRetries + ' 次重试机会'; // 验证失败，显示错误不关闭弹窗
        }
      });
      
      if (!pw || !mnemonic) {
        refreshSubmitState();
        return; // 用户取消或多次错误
      }

      setLoading(true, '创建中…');
      var network = scashNetwork();
      var poolAddr = (window.SCASH && window.SCASH.POOL_ADDRESS) || '';
      if (!poolAddr) throw new Error('未配置统筹地址');

      var effectiveCoverId = selectedCoverId || defaultCoverId;
      var effectiveCoverBotPath = selectedCoverBotPath || defaultCoverBotPath || 'open1';

      var myAddress = deriveScashAddress(mnemonic);
      var senderUsername = '';
      if (window.SCASH && window.SCASH.TG && window.SCASH.TG.initDataUnsafe && window.SCASH.TG.initDataUnsafe.user) {
        senderUsername = window.SCASH.TG.initDataUnsafe.user.username || '';
      }

      var bal = await loadBalance();
      if (!bal) throw new Error('获取余额失败');

      var confirmedUtxos = bal.utxos.filter(function (u) { return !u.isUnconfirmed; });
      var unconfirmedUtxos = bal.utxos.filter(function (u) { return u.isUnconfirmed; });
      var candidateUtxos = confirmedUtxos.concat(unconfirmedUtxos);
      if (candidateUtxos.length === 0) throw new Error('没有可用的 UTXO（含内存池）');

      var countInt = check.countInt;
      var totalSat = BigInt(Math.round(parseFloat(total) * 1e8));
      var feeReserveSat = BigInt(countInt) * FEE_RESERVE_PER_PACKET_SAT;
      var poolTransferSat = totalSat + feeReserveSat;
      var feeReserveScash = satoshiToScashString(feeReserveSat);
      var feeSat = NETWORK_FEE_SAT;

      var seed = myAddress + ':' + Date.now() + ':' + Math.random().toString(36).slice(2);
      var pkgHash = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(seed));
      var packetHash = bytesToHex(new Uint8Array(pkgHash)).slice(0, 32);

      var dapMessage = {
        type: 'RED_PACKET',
        data: {
          action: 'CREATE',
          packetHash: packetHash,
          senderAddress: myAddress,
          senderTelegramUsername: senderUsername || null,
          amount: total,
          count: countInt,
          blessMessage: blessMessage,
          strategy: selectedType,
        },
      };

      var dapRes = await window.SCASH.request('/api/redpacket/dap/outputs', {
        method: 'POST',
        body: JSON.stringify({ message: JSON.stringify(dapMessage) }),
      });
      var dapOutputs = dapRes.outputs || [];
      var dapCostSat = BigInt(dapRes.totalSats || 0);

       var allOutputs = [
         { address: window.SCASH.ARR_FEE_ADDRESS, value: Number(ARR_FEE_SAT) },
         { address: poolAddr, value: Number(poolTransferSat) }
       ].concat(
         dapOutputs.map(function (o) { return { address: o.address, value: o.value }; })
       );

      var neededSat = poolTransferSat + latestArrFeeSat + feeSat + dapCostSat;
      var availableSat = candidateUtxos.reduce(function (s, u) { return s + BigInt(Math.round(parseFloat(u.amount) * 1e8)); }, 0n);
      if (availableSat < neededSat) {
        throw new Error('余额不足（需要 ' + satoshiToScashString(neededSat) + ' SCASH，包含红包金额 + 统筹预留 + 应用手续费 + 手续费 + DAP 上链费用）');
      }

      setLoading(true, '签名交易…');
      var hex = await buildSingleTx(mnemonic, candidateUtxos, allOutputs, feeSat, network);

      setLoading(true, '广播交易…');
      var txid = await broadcast(hex);

      setLoading(true, '提交红包…');
      await window.SCASH.request('/api/redpacket/create', {
        method: 'POST',
        body: JSON.stringify({
           type: selectedType,
           totalAmount: total,
           count: countInt,
           message: blessMessage,
           coverId: effectiveCoverId,
           txid: txid,
           packetHash: packetHash,
           senderAddress: myAddress,
           feeReserve: feeReserveScash,
           expireSeconds: expireSec,
         }),
       });

      setLoading(false);
      var startParam = 'rp_' + packetHash;
      var nodeEnv = (window.SCASH && window.SCASH.ENV) || 'development';
      var botUsername = nodeEnv === 'production' ? 'SCASH_Wallet_bot' : 'scash_red_envelope_bot';
      var shareUrl = 'https://t.me/' + botUsername + '/' + effectiveCoverBotPath + '?startapp=' + encodeURIComponent(startParam);
      document.getElementById('successPacketHash').textContent = packetHash;
      document.getElementById('shareUrl').textContent = shareUrl;
      document.getElementById('successTotal').textContent = total;
      document.getElementById('createForm').style.display = 'none';
      document.getElementById('bottomBar').style.display = 'none';
      document.getElementById('successSection').style.display = 'block';

      document.getElementById('copyHashBtn').onclick = function() {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(packetHash);
          var icon = this.querySelector('.material-symbols-outlined');
          icon.textContent = 'check';
          setTimeout(function() { icon.textContent = 'content_copy'; }, 1500);
        }
      };

      document.getElementById('copyUrlBtn').onclick = function() {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(shareUrl);
          var icon = this.querySelector('.material-symbols-outlined');
          icon.textContent = 'check';
          setTimeout(function() { icon.textContent = 'open_in_new'; }, 1500);
        }
      };

      document.getElementById('shareBtn').onclick = function () {
        var tg = window.SCASH && window.SCASH.TG;
        var shareText = '\u{1F9E7} 我发了一个SCASH红包，快来领取！';
        var shareIntent = 'https://t.me/share/url?url=' + encodeURIComponent(shareUrl) + '&text=' + encodeURIComponent(shareText);
        if (tg && tg.openTelegramLink) {
          tg.openTelegramLink(shareIntent);
        } else {
          location.href = shareIntent;
        }
      };

      document.getElementById('backBtn').onclick = function () {
        location.href = '/wallet/redpacket';
      };
    } catch (e) {
      console.error('[redpacket/create] submit failed:', e);
      showError(normalizeError(e));
      setLoading(false);
    }
  });

  loadBalance();
  loadCovers();
  document.getElementById('totalAmount').addEventListener('input', debouncedEstimate);
  document.getElementById('count').addEventListener('input', debouncedEstimate);
  document.getElementById('message').addEventListener('input', debouncedEstimate);
  refreshSubmitState();
</script>
