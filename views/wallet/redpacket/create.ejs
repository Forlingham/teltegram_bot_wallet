<style>
  .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:200; align-items:center; justify-content:center; }
  .modal-overlay.active { display:flex; }
  .modal-box { background:#fff; border-radius:14px; padding:24px 20px; width:88vw; max-width:340px; box-shadow:0 12px 40px rgba(0,0,0,.25); }
  .modal-title { font-size:16px; font-weight:700; margin-bottom:14px; text-align:center; }
  .modal-body { font-size:13px; color:#444; margin-bottom:16px; white-space:pre-line; line-height:1.7; }
  .modal-input { width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:8px; font-size:14px; box-sizing:border-box; outline:none; }
  .modal-input:focus { border-color:var(--brand); }
  .modal-input.error { border-color:#c0392b; }
  .modal-pw-error { color:#c0392b; font-size:12px; margin-top:6px; min-height:18px; }
  .modal-actions { display:flex; gap:8px; }
  .modal-actions .btn { flex:1; }
  .expire-radio-group { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:12px; }
  .expire-radio { display:none; }
  .expire-label { padding:6px 12px; border:1.5px solid #ddd; border-radius:8px; font-size:12px; font-weight:600; color:#666; cursor:pointer; transition:all .15s; text-align:center; }
  .expire-radio:checked + .expire-label { border-color:var(--brand); color:var(--brand); background:rgba(46,125,50,.06); }
</style>

<div class="card">
  <div class="label">红包类型</div>
  <div class="row" style="margin-bottom:12px; gap:8px;">
    <button id="typeRandom" class="btn btn-brand type-btn" data-type="RANDOM" style="flex:1;">&#x1F3B2; 拼手气</button>
    <button id="typeEqual" class="btn btn-soft type-btn" data-type="EQUAL" style="flex:1;">&#x2694; 均分</button>
  </div>

  <div class="label">红包总金额 (SCASH)</div>
  <input id="totalAmount" type="text" placeholder="例如：10" autocomplete="off" style="margin-bottom:12px;" />

  <div class="label">红包个数</div>
  <input id="count" type="number" placeholder="例如：5" autocomplete="off" min="1" style="margin-bottom:12px;" />

  <div class="label">祝福语（选填）</div>
  <input id="message" type="text" placeholder="恭喜发财，大吉大利" autocomplete="off" maxlength="12" style="margin-bottom:12px;" />

  <div class="label">红包有效期</div>
  <div class="expire-radio-group" id="expireGroup">
    <% if (typeof env !== 'undefined' && env !== 'production') { %>
    <input class="expire-radio" type="radio" name="expireTime" id="expire180" value="180" checked />
    <label class="expire-label" for="expire180">3 分钟</label>
    <% } %>
    <input class="expire-radio" type="radio" name="expireTime" id="expire86400" value="86400" <%= (typeof env === 'undefined' || env === 'production') ? 'checked' : '' %> />
    <label class="expire-label" for="expire86400">24 小时</label>
    <input class="expire-radio" type="radio" name="expireTime" id="expire604800" value="604800" />
    <label class="expire-label" for="expire604800">7 天</label>
    <input class="expire-radio" type="radio" name="expireTime" id="expire31536000" value="31536000" />
    <label class="expire-label" for="expire31536000">永不过期</label>
  </div>

  <div class="label">选择封面</div>
  <div id="coverList" style="margin-bottom:12px; display:flex; gap:8px; overflow-x:auto; padding-bottom:4px;">
    <div style="color:var(--muted); font-size:12px; padding:8px 0;">加载中…</div>
  </div>

  <div class="row" style="margin-bottom:8px;">
    <span class="label" style="margin:0;">可用余额：</span>
    <span id="availBalance" class="value" style="font-size:14px;">- SCASH</span>
  </div>

  <div class="card warn" style="margin-bottom:12px;">
    <div class="label" style="margin-bottom:6px;">费用预估</div>
    <div class="row" style="margin-bottom:4px;"><span class="label" style="margin:0;">红包金额</span><span id="estAmount" class="mono">-</span></div>
    <div class="row" style="margin-bottom:4px;"><span class="label" style="margin:0;">统筹预留</span><span id="estReserve" class="mono">-</span></div>
    <div class="row" style="margin-bottom:4px;"><span class="label" style="margin:0;">链上手续费</span><span id="estFee" class="mono">-</span></div>
    <div class="row" style="margin-bottom:6px;"><span class="label" style="margin:0;">DAP 上链</span><span id="estDap" class="mono">计算中…</span></div>
    <div class="row" style="padding-top:6px; border-top:1px dashed #e3d2b7;"><span style="font-size:13px; font-weight:700;">预计总支出</span><span id="estTotal" class="mono" style="font-weight:700;">-</span></div>
  </div>

  <button id="submitBtn" class="btn btn-brand" style="width:100%;">&#x1F4E5; 确认创建</button>
  <div id="errorMsg" class="error" style="display:none; margin-top:10px;"></div>
</div>

<!-- 确认弹窗 -->
<div id="confirmModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-title">确认红包信息</div>
    <div class="modal-body" id="confirmBody"></div>
    <div class="modal-actions">
      <button class="btn btn-soft" id="confirmCancel">取消</button>
      <button class="btn btn-brand" id="confirmOk">确认发送</button>
    </div>
  </div>
</div>

<!-- 密码弹窗 -->
<div id="pwModal" class="modal-overlay">
  <div class="modal-box">
    <div class="modal-title">输入钱包密码</div>
    <input id="pwInput" class="modal-input" type="password" placeholder="请输入钱包密码以签署交易" autocomplete="off" />
    <div class="modal-pw-error" id="pwError"></div>
    <div class="modal-actions">
      <button class="btn btn-soft" id="pwCancel">取消</button>
      <button class="btn btn-brand" id="pwOk">确认</button>
    </div>
  </div>
</div>

<div id="successSection" style="display:none;">
  <div class="card" style="text-align:center;">
    <div style="font-size:48px; margin-bottom:12px;">&#x1F389;</div>
    <div style="font-size:18px; font-weight:700; margin-bottom:8px;">红包已发出！</div>
    <div class="label" style="margin-bottom:16px;" id="successPacketHash">-</div>
    <div class="card warn" style="margin-bottom:16px; text-align:left;">
      <div class="label" style="margin-bottom:4px;">分享链接</div>
      <div id="shareUrl" class="mono" style="font-size:11px; word-break:break-all; color:var(--brand); margin-bottom:8px;">-</div>
    </div>
    <button id="shareBtn" class="btn btn-brand" style="width:100%;">&#x1F4E4; 分享到聊天</button>
    <button id="backBtn" class="btn btn-soft" style="width:100%; margin-top:8px;">返回红包</button>
  </div>
</div>

<script type="module">
  import * as bitcoin from 'https://esm.sh/bitcoinjs-lib@6.1.5';
  import * as bip39 from 'https://esm.sh/bip39@3.1.0';
  import { HDKey } from 'https://esm.sh/@scure/bip32@1.4.0';
  import { bech32 } from 'https://esm.sh/bech32@2.0.0';
  import { hmac } from 'https://esm.sh/@noble/hashes@1.5.0/hmac';
  import { sha256 } from 'https://esm.sh/@noble/hashes@1.5.0/sha256';
  import { ripemd160 } from 'https://esm.sh/@noble/hashes@1.5.0/ripemd160';
  import * as secp from 'https://esm.sh/@noble/secp256k1@2.1.0';
  import { Buffer } from 'https://esm.sh/buffer@6.0.3';
  
  if (typeof window.Buffer === 'undefined') window.Buffer = Buffer;

  function concatBytes() {
    var total = 0;
    for (var i = 0; i < arguments.length; i++) total += arguments[i].length;
    var out = new Uint8Array(total);
    var offset = 0;
    for (var j = 0; j < arguments.length; j++) {
      out.set(arguments[j], offset);
      offset += arguments[j].length;
    }
    return out;
  }

  secp.etc.hmacSha256Sync = function (key) {
    var msgs = [];
    for (var i = 1; i < arguments.length; i++) msgs.push(arguments[i]);
    return hmac(sha256, key, concatBytes.apply(null, msgs));
  };

  secp.etc.hmacSha256Async = async function (key) {
    var msgs = [];
    for (var i = 1; i < arguments.length; i++) msgs.push(arguments[i]);
    return hmac(sha256, key, concatBytes.apply(null, msgs));
  };

  function toBytes(input) {
    if (!input) throw new Error('签名结果为空');
    if (input instanceof Uint8Array) return input;
    if (Array.isArray(input)) return new Uint8Array(input);
    if (typeof input === 'string') {
      if (/^[0-9a-fA-F]+$/.test(input) && input.length % 2 === 0) {
        var parts = input.match(/.{2}/g) || [];
        return new Uint8Array(parts.map(function (b) { return parseInt(b, 16); }));
      }
      return new TextEncoder().encode(input);
    }
    if (typeof input.toCompactRawBytes === 'function') return input.toCompactRawBytes();
    if (typeof input.toRawBytes === 'function') return input.toRawBytes();
    if (input.buffer instanceof ArrayBuffer) return new Uint8Array(input.buffer, input.byteOffset || 0, input.byteLength || input.length || 0);
    throw new Error('不支持的字节类型: ' + Object.prototype.toString.call(input));
  }


  let selectedType = 'RANDOM';
  let selectedCoverId = null;
  let selectedCoverBotPath = 'open1';
  let defaultCoverId = null;
  let defaultCoverBotPath = 'open1';
  const FEE_RESERVE_PER_PACKET_SAT = 100000n; // 0.001 SCASH
  const NETWORK_FEE_SAT = 10000n; // 0.0001 SCASH
  const MAX_PACKET_COUNT = 200;
  const MAX_TOTAL_SCASH = 1000000;
  let cachedBalanceSat = null;
  let latestDapCostSat = 0n;
  let latestEstimateTotalSat = null;
  let estimateSeq = 0;
  let isEstimating = false;
  let isSubmitting = false;
  let loadingText = '处理中…';

  function getSelectedExpireSeconds() {
    var checked = document.querySelector('input[name="expireTime"]:checked');
    return checked ? parseInt(checked.value, 10) : 86400;
  }

  function scashNetwork() {
    var net = (window.SCASH && window.SCASH.NETWORK) || {};
    return {
      messagePrefix: '\x18Scash Signed Message:\n',
      bech32: net.bech32 || 'bcrt',
      bip32: { public: 0x0488b21e, private: 0x0488ade4 },
      pubKeyHash: net.pubKeyHash || 60,
      scriptHash: net.scriptHash || 125,
      wif: 0x80,
    };
  }

  function refreshSubmitState() {
    var btn = document.getElementById('submitBtn');
    btn.disabled = isEstimating || isSubmitting;
    if (isSubmitting) {
      btn.innerHTML = '<span class="spinner"></span>' + loadingText;
    } else {
      btn.textContent = '\u{1F4E5} 确认创建';
    }
  }

  function setLoading(on, text) {
    isSubmitting = on;
    loadingText = text || '处理中…';
    refreshSubmitState();
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    if (!msg) {
      el.textContent = '';
      el.style.display = 'none';
      return;
    }
    el.textContent = msg;
    el.style.display = 'block';
  }

  function normalizeError(err) {
    if (!err) return '未知错误';
    if (typeof err === 'string') return err;
    if (err.message) return err.message;
    try { return JSON.stringify(err); } catch (_) { return String(err); }
  }

  function bytesToHex(arr) {
    return Array.from(new Uint8Array(arr)).map(function (b) { return b.toString(16).padStart(2, '0'); }).join('');
  }

  function satoshiToScashString(sats) {
    var sign = sats < 0n ? '-' : '';
    var abs = sats < 0n ? -sats : sats;
    var whole = abs / 100000000n;
    var frac = (abs % 100000000n).toString().padStart(8, '0');
    return sign + whole.toString() + '.' + frac;
  }

  function parseScashToSats(value) {
    var s = String(value || '').trim();
    if (!/^\d+(\.\d{1,8})?$/.test(s)) return null;
    var parts = s.split('.');
    var whole = BigInt(parts[0] || '0');
    var frac = ((parts[1] || '') + '00000000').slice(0, 8);
    return whole * 100000000n + BigInt(frac);
  }

  function getSenderUsername() {
    var tg = window.SCASH && window.SCASH.TG;
    return (tg && tg.initDataUnsafe && tg.initDataUnsafe.user && tg.initDataUnsafe.user.username) || '';
  }

  function validateForm() {
    var total = document.getElementById('totalAmount').value.trim();
    var count = document.getElementById('count').value.trim();
    var totalSat = parseScashToSats(total);
    var countInt = parseInt(count, 10);

    if (!total) return { ok: false, message: '请输入红包总金额' };
    if (totalSat === null || totalSat <= 0n) return { ok: false, message: '金额格式不正确（最多8位小数）' };
    if (parseFloat(total) > MAX_TOTAL_SCASH) return { ok: false, message: '金额过大，请分批发送' };
    if (!count || isNaN(countInt) || countInt <= 0) return { ok: false, message: '请输入有效红包个数' };
    if (countInt > MAX_PACKET_COUNT) return { ok: false, message: '红包个数过多，最多 ' + MAX_PACKET_COUNT + ' 个' };
    var message = document.getElementById('message').value.trim();
    if (Array.from(message).length > 12) return { ok: false, message: '祝福语最多 12 个字' };

    var reserveSat = BigInt(countInt) * FEE_RESERVE_PER_PACKET_SAT;
    var totalNeed = totalSat + reserveSat + NETWORK_FEE_SAT + latestDapCostSat;
    if (cachedBalanceSat !== null && totalNeed > cachedBalanceSat) {
      return { ok: false, message: '余额不足，预计至少需要 ' + satoshiToScashString(totalNeed) + ' SCASH' };
    }

    return {
      ok: true,
      total: total,
      totalSat: totalSat,
      countInt: countInt,
      reserveSat: reserveSat,
      totalNeedSat: totalNeed,
    };
  }

  function renderEstimate(data) {
    document.getElementById('estAmount').textContent = data.amount;
    document.getElementById('estReserve').textContent = data.reserve;
    document.getElementById('estFee').textContent = data.fee;
    document.getElementById('estDap').textContent = data.dap;
    document.getElementById('estTotal').textContent = data.total;
  }

  async function updateEstimate() {
    isEstimating = true;
    refreshSubmitState();

    var v = validateForm();
    if (!v.ok && !String(v.message || '').startsWith('余额不足')) {
      latestEstimateTotalSat = null;
      renderEstimate({ amount: '-', reserve: '-', fee: satoshiToScashString(NETWORK_FEE_SAT) + ' SCASH', dap: '-', total: '-' });
      isEstimating = false;
      refreshSubmitState();
      return;
    }

    renderEstimate({
      amount: satoshiToScashString(v.totalSat) + ' SCASH',
      reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
      fee: satoshiToScashString(NETWORK_FEE_SAT) + ' SCASH',
      dap: '计算中…',
      total: '计算中…',
    });

    var seq = ++estimateSeq;
    var blessMessage = (document.getElementById('message').value.trim() || '恭喜发财，大吉大利');
    var dapMessage = {
      type: 'RED_PACKET',
      data: {
        action: 'CREATE',
        packetHash: 'preview_preview_preview_preview',
        senderAddress: 'preview',
        senderTelegramUsername: getSenderUsername() || null,
        amount: v.total,
        count: v.countInt,
        blessMessage: blessMessage,
        strategy: selectedType,
      },
    };

    try {
      var dapRes = await window.SCASH.request('/api/redpacket/dap/outputs', {
        method: 'POST',
        body: JSON.stringify({ message: JSON.stringify(dapMessage) }),
      });
      if (seq !== estimateSeq) return;

      latestDapCostSat = BigInt(dapRes.totalSats || 0);
      latestEstimateTotalSat = v.totalSat + v.reserveSat + NETWORK_FEE_SAT + latestDapCostSat;

      renderEstimate({
        amount: satoshiToScashString(v.totalSat) + ' SCASH',
        reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
        fee: satoshiToScashString(NETWORK_FEE_SAT) + ' SCASH',
        dap: satoshiToScashString(latestDapCostSat) + ' SCASH',
        total: satoshiToScashString(latestEstimateTotalSat) + ' SCASH',
      });
    } catch (e) {
      if (seq !== estimateSeq) return;
      latestDapCostSat = 0n;
      latestEstimateTotalSat = null;
      renderEstimate({
        amount: satoshiToScashString(v.totalSat) + ' SCASH',
        reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
        fee: satoshiToScashString(NETWORK_FEE_SAT) + ' SCASH',
        dap: '计算失败',
        total: '-',
      });
    } finally {
      isEstimating = false;
      refreshSubmitState();
    }
  }

  function debounce(fn, wait) {
    var t = null;
    return function () {
      clearTimeout(t);
      t = setTimeout(fn, wait);
    };
  }

  var debouncedEstimate = debounce(updateEstimate, 350);

  function deriveScashAddress(mnemonic) {
    var seed = bip39.mnemonicToSeedSync(mnemonic);
    var root = HDKey.fromMasterSeed(seed);
    var child = root.derive("m/84'/0'/0'/0/0");
    var pubKey = child.publicKey;
    if (!pubKey) throw new Error('Cannot derive public key');
    var hash = ripemd160(sha256(pubKey));
    var words = bech32.toWords(hash);
    words.unshift(0);
    return bech32.encode(scashNetwork().bech32, words);
  }

  async function decryptMnemonic(password) {
    var data = await window.SCASH.request('/api/wallet/recover', { method: 'POST', body: '{}' });
    if (!data.backup) throw new Error('未找到钱包备份，无法发送');

    function hexToBytes(hex) {
      if (!hex || typeof hex !== 'string') throw new Error('备份数据格式错误');
      var parts = hex.match(/.{2}/g);
      if (!parts) throw new Error('备份数据格式错误');
      return new Uint8Array(parts.map(function (b) { return parseInt(b, 16); }));
    }

    function concatBytes(a, b) {
      var out = new Uint8Array(a.length + b.length);
      out.set(a, 0);
      out.set(b, a.length);
      return out;
    }

    var saltBytes = hexToBytes(data.backup.salt);
    var ivBytes = hexToBytes(data.backup.iv);
    var cipherHex = data.backup.encryptedMnemonic || data.backup.ciphertext;
    var ctBytes = hexToBytes(cipherHex);
    var tagBytes = null;
    try {
      if (data.backup.authTag) tagBytes = hexToBytes(data.backup.authTag);
    } catch (_) {}

    var keyMaterial = await crypto.subtle.importKey('raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveBits']);
    var keyBits = await crypto.subtle.deriveBits({ name: 'PBKDF2', salt: saltBytes, iterations: 100000, hash: 'SHA-256' }, keyMaterial, 256);
    var aesKey = await crypto.subtle.importKey('raw', keyBits, 'AES-GCM', false, ['decrypt']);

    var candidates = [ctBytes];
    if (tagBytes && tagBytes.length > 0) {
      candidates.push(concatBytes(ctBytes, tagBytes));
      candidates.push(concatBytes(tagBytes, ctBytes));
    }

    for (var i = 0; i < candidates.length; i++) {
      try {
        var pt = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: ivBytes, tagLength: 128 }, aesKey, candidates[i]);
        return new TextDecoder().decode(pt);
      } catch (_) {}
    }

    throw new Error('钱包密码错误');
  }

  async function broadcast(hex) {
    var res = await window.SCASH.request('/api/wallet/broadcast', {
      method: 'POST',
      body: JSON.stringify({ hex: hex }),
    });
    return res.txid;
  }

  async function buildSingleTx(mnemonic, utxos, outputs, feeSat, network) {
    var seed = bip39.mnemonicToSeedSync(mnemonic);
    var rootKey = HDKey.fromMasterSeed(seed);
    var childKey = rootKey.derive("m/84'/0'/0'/0/0");
    var myAddress = deriveScashAddress(mnemonic);

    var privKey = childKey.privateKey;
    var pubKey = childKey.publicKey;
    if (!privKey || !pubKey) throw new Error('无法派生签名密钥');

    var psbt = new bitcoin.Psbt({ network: network });
    var totalInputSat = 0n;
    var selectedUtxos = [];
    var outputsTotalSat = outputs.reduce(function (s, o) { return s + BigInt(o.value || 0); }, 0n);

    for (var i = 0; i < utxos.length; i++) {
      var u = utxos[i];
      if (!u || !u.txid || typeof u.vout !== 'number' || !u.amount) continue;
      var uSat = BigInt(Math.round(parseFloat(u.amount) * 1e8));
      var script = bitcoin.address.toOutputScript(myAddress, network);
      psbt.addInput({
        hash: u.txid,
        index: u.vout,
        witnessUtxo: {
          script: script,
          value: Number(uSat),
        },
      });
      selectedUtxos.push(uSat);
      totalInputSat += uSat;
      if (totalInputSat >= outputsTotalSat + feeSat) break;
    }

    if (totalInputSat < outputsTotalSat + feeSat) {
      throw new Error('UTXO 余额不足（含手续费）');
    }

    for (var j = 0; j < outputs.length; j++) {
      psbt.addOutput({ address: outputs[j].address, value: Number(outputs[j].value) });
    }

    var changeSat = totalInputSat - outputsTotalSat - feeSat;
    if (changeSat > 0n) {
      psbt.addOutput({ address: myAddress, value: Number(changeSat) });
    }

    var signer = {
      publicKey: Buffer.from(pubKey),
      sign: async function (hash) {
        var sig = await secp.sign(new Uint8Array(hash), privKey);
        return Buffer.from(toBytes(sig));
      },
    };

    for (var k = 0; k < selectedUtxos.length; k++) {
      await psbt.signInputAsync(k, signer);
    }

    psbt.finalizeAllInputs();
    return psbt.extractTransaction().toHex();
  }

  // --- Modal helpers ---
  function showConfirmModal(text) {
    return new Promise(function (resolve) {
      document.getElementById('confirmBody').textContent = text;
      var modal = document.getElementById('confirmModal');
      modal.classList.add('active');
      function cleanup(val) {
        modal.classList.remove('active');
        document.getElementById('confirmOk').removeEventListener('click', onOk);
        document.getElementById('confirmCancel').removeEventListener('click', onCancel);
        resolve(val);
      }
      function onOk() { cleanup(true); }
      function onCancel() { cleanup(false); }
      document.getElementById('confirmOk').addEventListener('click', onOk);
      document.getElementById('confirmCancel').addEventListener('click', onCancel);
    });
  }

  function showPasswordModal(initError) {
    return new Promise(function (resolve) {
      var modal = document.getElementById('pwModal');
      var input = document.getElementById('pwInput');
      var errEl = document.getElementById('pwError');
      var okBtn = document.getElementById('pwOk');
      input.value = '';
      okBtn.disabled = false;
      okBtn.textContent = '确认';
      if (initError) {
        errEl.textContent = initError;
        input.classList.add('error');
      } else {
        errEl.textContent = '';
        input.classList.remove('error');
      }
      modal.classList.add('active');
      setTimeout(function () { input.focus(); }, 100);
      function cleanup(val) {
        modal.classList.remove('active');
        okBtn.removeEventListener('click', onOk);
        document.getElementById('pwCancel').removeEventListener('click', onCancel);
        input.removeEventListener('keydown', onKey);
        resolve(val);
      }
      function onOk() { cleanup(input.value || ''); }
      function onCancel() { cleanup(null); }
      function onKey(e) { if (e.key === 'Enter') onOk(); }
      okBtn.addEventListener('click', onOk);
      document.getElementById('pwCancel').addEventListener('click', onCancel);
      input.addEventListener('keydown', onKey);
    });
  }

  function showPwError(msg) {
    var errEl = document.getElementById('pwError');
    var input = document.getElementById('pwInput');
    errEl.textContent = msg || '';
    if (msg) { input.classList.add('error'); } else { input.classList.remove('error'); }
  }

  document.querySelectorAll('.type-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.type-btn').forEach(function (b) { b.classList.remove('btn-brand'); b.classList.add('btn-soft'); });
      btn.classList.remove('btn-soft'); btn.classList.add('btn-brand');
      selectedType = btn.dataset.type;
      debouncedEstimate();
    });
  });

  async function loadBalance() {
    try {
      var bal = await window.SCASH.request('/api/wallet/balance?includeUnconfirmed=true');
      document.getElementById('availBalance').textContent = bal.balance + ' SCASH';
      cachedBalanceSat = parseScashToSats(bal.balance);
      return bal;
    } catch (e) {
      showError('获取余额失败：' + e.message);
      return null;
    }
  }

  async function loadCovers() {
    try {
      var covers = await window.SCASH.request('/api/cover/list');
      var el = document.getElementById('coverList');
      if (!covers || covers.length === 0) {
        el.innerHTML = '<div style="color:var(--muted); font-size:12px;">暂无可用封面</div>';
        return;
      }
      defaultCoverId = covers[0].id;
      defaultCoverBotPath = covers[0].botPath || ('open' + covers[0].id);
      if (!selectedCoverBotPath) selectedCoverBotPath = defaultCoverBotPath;

      el.innerHTML = covers.map(function (c) {
        return '<div class="cover-item" data-id="' + c.id + '" data-botpath="' + (c.botPath || 'open' + c.id) + '" style="min-width:64px; text-align:center; cursor:pointer; border:2px solid transparent; border-radius:8px; padding:4px;">' +
          '<img src="' + c.imageUrl + '" style="width:56px; height:56px; object-fit:cover; border-radius:6px;" />' +
          '<div style="font-size:10px; margin-top:2px; color:var(--muted);">' + c.name + '</div>' +
        '</div>';
      }).join('');
      el.querySelectorAll('.cover-item').forEach(function (item) {
        item.addEventListener('click', function () {
          el.querySelectorAll('.cover-item').forEach(function (i) { i.style.borderColor = 'transparent'; });
          item.style.borderColor = 'var(--brand)';
          selectedCoverId = parseInt(item.dataset.id);
          selectedCoverBotPath = item.dataset.botpath || ('open' + selectedCoverId);
        });
      });
      debouncedEstimate();
    } catch (e) {
      document.getElementById('coverList').innerHTML = '<div style="color:var(--muted); font-size:12px;">加载封面失败</div>';
    }
  }

  document.getElementById('submitBtn').addEventListener('click', async function () {
    if (isSubmitting) return;

    var total = document.getElementById('totalAmount').value.trim();
    var count = document.getElementById('count').value.trim();
    var message = document.getElementById('message').value.trim();
    var blessMessage = message || '恭喜发财，大吉大利';
    showError('');

    try {
      await updateEstimate();
      var check = validateForm();
      if (!check.ok) {
        showError(check.message);
        return;
      }

      var expireSec = getSelectedExpireSeconds();
      var expireLabel = { 180: '3 分钟', 86400: '24 小时', 604800: '7 天', 31536000: '永不过期' }[expireSec] || (expireSec + ' 秒');

      var confirmText = [
        '类型：' + (selectedType === 'RANDOM' ? '拼手气' : '均分'),
        '金额：' + check.total + ' SCASH',
        '个数：' + check.countInt,
        '祝福语：' + blessMessage,
        '有效期：' + expireLabel,
        '预计总支出：' + (latestEstimateTotalSat ? satoshiToScashString(latestEstimateTotalSat) : satoshiToScashString(check.totalNeedSat)) + ' SCASH',
      ].join('\n');

      var confirmed = await showConfirmModal(confirmText);
      if (!confirmed) return;

      // 密码输入循环：允许重试（最多2次）
      var mnemonic = null;
      var pwRetries = 2;
      var pwErrMsg = null;
      while (pwRetries > 0) {
        var pw = await showPasswordModal(pwErrMsg);
        if (pw === null) return; // 用户取消
        if (!pw) {
          pwErrMsg = '请输入密码';
          continue;
        }
        try {
          document.getElementById('pwOk').disabled = true;
          document.getElementById('pwOk').innerHTML = '<span class="spinner"></span>验证中…';
          mnemonic = await decryptMnemonic(pw);
          document.getElementById('pwOk').disabled = false;
          document.getElementById('pwOk').textContent = '确认';
          document.getElementById('pwModal').classList.remove('active');
          break;
        } catch (pwErr) {
          document.getElementById('pwOk').disabled = false;
          document.getElementById('pwOk').textContent = '确认';
          pwRetries--;
          if (pwRetries <= 0) {
            document.getElementById('pwModal').classList.remove('active');
            showError('密码多次错误，请确认后重试');
            return;
          }
          pwErrMsg = '密码错误，请重新输入';
        }
      }

      setLoading(true, '创建中…');
      var network = scashNetwork();
      var poolAddr = (window.SCASH && window.SCASH.POOL_ADDRESS) || '';
      if (!poolAddr) throw new Error('未配置统筹地址');

      var effectiveCoverId = selectedCoverId || defaultCoverId;
      var effectiveCoverBotPath = selectedCoverBotPath || defaultCoverBotPath || 'open1';

      var myAddress = deriveScashAddress(mnemonic);
      var senderUsername = '';
      if (window.SCASH && window.SCASH.TG && window.SCASH.TG.initDataUnsafe && window.SCASH.TG.initDataUnsafe.user) {
        senderUsername = window.SCASH.TG.initDataUnsafe.user.username || '';
      }

      var bal = await loadBalance();
      if (!bal) throw new Error('获取余额失败');

      var confirmedUtxos = bal.utxos.filter(function (u) { return !u.isUnconfirmed; });
      var unconfirmedUtxos = bal.utxos.filter(function (u) { return u.isUnconfirmed; });
      var candidateUtxos = confirmedUtxos.concat(unconfirmedUtxos);
      if (candidateUtxos.length === 0) throw new Error('没有可用的 UTXO（含内存池）');

      var countInt = check.countInt;
      var totalSat = BigInt(Math.round(parseFloat(total) * 1e8));
      var feeReserveSat = BigInt(countInt) * FEE_RESERVE_PER_PACKET_SAT;
      var poolTransferSat = totalSat + feeReserveSat;
      var feeReserveScash = satoshiToScashString(feeReserveSat);
      var feeSat = NETWORK_FEE_SAT;

      var seed = myAddress + ':' + Date.now() + ':' + Math.random().toString(36).slice(2);
      var pkgHash = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(seed));
      var packetHash = bytesToHex(new Uint8Array(pkgHash)).slice(0, 32);

      var dapMessage = {
        type: 'RED_PACKET',
        data: {
          action: 'CREATE',
          packetHash: packetHash,
          senderAddress: myAddress,
          senderTelegramUsername: senderUsername || null,
          amount: total,
          count: countInt,
          blessMessage: blessMessage,
          strategy: selectedType,
        },
      };

      var dapRes = await window.SCASH.request('/api/redpacket/dap/outputs', {
        method: 'POST',
        body: JSON.stringify({ message: JSON.stringify(dapMessage) }),
      });
      var dapOutputs = dapRes.outputs || [];
      var dapCostSat = BigInt(dapRes.totalSats || 0);

       var allOutputs = [{ address: poolAddr, value: Number(poolTransferSat) }].concat(
         dapOutputs.map(function (o) { return { address: o.address, value: o.value }; })
       );

      var neededSat = poolTransferSat + feeSat + dapCostSat;
      var availableSat = candidateUtxos.reduce(function (s, u) { return s + BigInt(Math.round(parseFloat(u.amount) * 1e8)); }, 0n);
      if (availableSat < neededSat) {
        throw new Error('余额不足（需要 ' + satoshiToScashString(neededSat) + ' SCASH，包含红包金额 + 统筹手续费预留 + 手续费 + DAP 上链费用）');
      }

      setLoading(true, '签名交易…');
      var hex = await buildSingleTx(mnemonic, candidateUtxos, allOutputs, feeSat, network);

      setLoading(true, '广播交易…');
      var txid = await broadcast(hex);

      setLoading(true, '提交红包…');
      await window.SCASH.request('/api/redpacket/create', {
        method: 'POST',
        body: JSON.stringify({
           type: selectedType,
           totalAmount: total,
           count: countInt,
           message: blessMessage,
           coverId: effectiveCoverId,
           txid: txid,
           packetHash: packetHash,
           senderAddress: myAddress,
           feeReserve: feeReserveScash,
           expireSeconds: expireSec,
         }),
       });

      setLoading(false);
      var startParam = 'rp_' + packetHash;
      var shareUrl = 'https://t.me/scash_red_envelope_bot/' + effectiveCoverBotPath + '?startapp=' + encodeURIComponent(startParam);
      document.getElementById('successPacketHash').textContent = packetHash;
      document.getElementById('shareUrl').textContent = shareUrl;
      document.getElementById('submitBtn').closest('.card').style.display = 'none';
      document.getElementById('successSection').style.display = 'block';

      document.getElementById('shareBtn').onclick = function () {
        var tg = window.SCASH && window.SCASH.TG;
        var shareText = '\u{1F9E7} 我发了一个SCASH红包，快来领取！';
        var shareIntent = 'https://t.me/share/url?url=' + encodeURIComponent(shareUrl) + '&text=' + encodeURIComponent(shareText);
        if (tg && tg.openTelegramLink) {
          tg.openTelegramLink(shareIntent);
        } else {
          location.href = shareIntent;
        }
      };

      document.getElementById('backBtn').onclick = function () {
        location.href = '/wallet/redpacket';
      };
    } catch (e) {
      console.error('[redpacket/create] submit failed:', e);
      showError(normalizeError(e));
      setLoading(false);
    }
  });

  loadBalance();
  loadCovers();
  document.getElementById('totalAmount').addEventListener('input', debouncedEstimate);
  document.getElementById('count').addEventListener('input', debouncedEstimate);
  document.getElementById('message').addEventListener('input', debouncedEstimate);
  refreshSubmitState();
</script>
