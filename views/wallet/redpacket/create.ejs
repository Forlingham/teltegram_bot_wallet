<div class="card">
  <div class="label">红包总金额 (SCASH)</div>
  <input id="totalAmount" type="text" placeholder="例如：10.5" autocomplete="off" style="margin-bottom:12px;" />

  <div class="label">红包个数</div>
  <input id="count" type="number" placeholder="例如：5" autocomplete="off" min="1" style="margin-bottom:12px;" />

  <div class="label">祝福语（选填）</div>
  <input id="message" type="text" placeholder="恭喜发财，大吉大利" autocomplete="off" style="margin-bottom:16px;" />

  <div class="row" style="margin-bottom:16px;">
    <span class="label" style="margin:0;">可用余额：</span>
    <span id="availBalance" class="value" style="font-size:14px;">- SCASH</span>
  </div>

  <button id="submitBtn" class="btn btn-brand" style="width:100%;">塞钱进红包</button>
  <div id="errorMsg" class="error" style="display:none; margin-top:10px;"></div>
</div>

<script>
  async function loadBalance() {
    try {
      var bal = await window.SCASH.request('/api/wallet/balance');
      document.getElementById('availBalance').textContent = bal.balance + ' SCASH';
    } catch (e) {}
  }

  function setLoading(on) {
    var btn = document.getElementById('submitBtn');
    if (on) { btn.disabled = true; btn.innerHTML = '<span class="spinner"></span>发送中…'; }
    else { btn.disabled = false; btn.textContent = '塞钱进红包'; }
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = msg; el.style.display = 'block';
  }

  document.getElementById('submitBtn').addEventListener('click', async function () {
    var total = document.getElementById('totalAmount').value.trim();
    var count = document.getElementById('count').value.trim();
    var message = document.getElementById('message').value.trim();
    showError('');
    if (!total || isNaN(parseFloat(total)) || parseFloat(total) <= 0) { showError('请输入有效金额'); return; }
    if (!count || isNaN(parseInt(count)) || parseInt(count) <= 0) { showError('请输入有效个数'); return; }
    setLoading(true);
    try {
      var res = await window.SCASH.request('/api/redpacket/create', {
        method: 'POST',
        body: JSON.stringify({
          totalAmount: total,
          count: parseInt(count),
          message: message || '恭喜发财，大吉大利',
        }),
      });
      alert('红包已发出！');
      location.href = '/wallet/redpacket';
    } catch (e) {
      showError(e.message);
      setLoading(false);
    }
  });

  loadBalance();
</script>