  async function updateEstimate() {
    isEstimating = true;
    refreshSubmitState();

    var v = validateForm();
    updateFiatEstimate(v.totalSat);
    if (!v.ok && !String(v.message || '').startsWith('余额不足')) {
      latestEstimateTotalSat = null;
      renderEstimate({ amount: '-', reserve: '-', fee: satoshiToScashTrimmed(NETWORK_FEE_SAT) + ' SCASH', arrFee: satoshiToScashTrimmed(ARR_FEE_SAT) + ' SCASH', dap: '-', total: '-' });
      isEstimating = false;
      refreshSubmitState();
      return;
    }

    renderEstimate({
      amount: satoshiToScashString(v.totalSat) + ' SCASH',
      reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
      fee: satoshiToScashTrimmed(NETWORK_FEE_SAT) + ' SCASH',
      dap: '计算中…',
      total: '计算中…',
    });

    var seq = ++estimateSeq;
    var blessMessage = (document.getElementById('message').value.trim() || '恭喜发财，大吉大利');
    var dapMessage = {
      type: 'RED_PACKET',
      data: {
        action: 'CREATE',
        packetHash: 'preview_preview_preview_preview',
        senderAddress: 'preview',
        senderTelegramUsername: getSenderUsername() || null,
        amount: v.total,
        count: v.countInt,
        blessMessage: blessMessage,
        strategy: selectedType,
      },
    };

    try {
      var dapRes = await window.SCASH.request('/api/redpacket/dap/outputs', {
        method: 'POST',
        body: JSON.stringify({ message: JSON.stringify(dapMessage) }),
      });
      if (seq !== estimateSeq) return;

      latestDapCostSat = BigInt(dapRes.totalSats || 0);
      latestArrFeeSat = ARR_FEE_SAT;
      latestEstimateTotalSat = v.totalSat + v.reserveSat + latestArrFeeSat + NETWORK_FEE_SAT + latestDapCostSat;

      renderEstimate({
        amount: satoshiToScashString(v.totalSat) + ' SCASH',
        reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
        fee: satoshiToScashTrimmed(NETWORK_FEE_SAT) + ' SCASH',
        arrFee: satoshiToScashTrimmed(latestArrFeeSat) + ' SCASH',
        dap: satoshiToScashTrimmed(latestDapCostSat) + ' SCASH',
        total: satoshiToScashTrimmed(latestEstimateTotalSat) + ' SCASH',
      });
    } catch (e) {
      if (seq !== estimateSeq) return;
      latestDapCostSat = 0n;
      latestEstimateTotalSat = null;
      renderEstimate({
        amount: satoshiToScashString(v.totalSat) + ' SCASH',
        reserve: satoshiToScashString(v.reserveSat) + ' SCASH',
        fee: satoshiToScashTrimmed(NETWORK_FEE_SAT) + ' SCASH',
        dap: '计算失败',
        total: '-',
      });
    } finally {
      isEstimating = false;
      refreshSubmitState();
    }
  }

  function debounce(fn, wait) {
    var t = null;
    return function () {
      clearTimeout(t);
      t = setTimeout(fn, wait);
    };
  }

  var debouncedEstimate = debounce(updateEstimate, 350);

  function deriveScashAddress(mnemonic) {
    var seed = bip39.mnemonicToSeedSync(mnemonic);
    var root = HDKey.fromMasterSeed(seed);
    var child = root.derive("m/84'/0'/0'/0/0");
    var pubKey = child.publicKey;
    if (!pubKey) throw new Error('Cannot derive public key');
    var hash = ripemd160(sha256(pubKey));
    var words = bech32.toWords(hash);
    words.unshift(0);
    return bech32.encode(scashNetwork().bech32, words);
  }

  async function decryptMnemonic(password) {
    var data = await window.SCASH.request('/api/wallet/recover', { method: 'POST', body: '{}' });
    if (!data.backup) throw new Error('未找到钱包备份，无法发送');

    function hexToBytes(hex) {
      if (!hex || typeof hex !== 'string') throw new Error('备份数据格式错误');
      var parts = hex.match(/.{2}/g);
      if (!parts) throw new Error('备份数据格式错误');
      return new Uint8Array(parts.map(function (b) { return parseInt(b, 16); }));
    }

    function concatBytes(a, b) {
      var out = new Uint8Array(a.length + b.length);
      out.set(a, 0);
      out.set(b, a.length);
      return out;
    }

    var saltBytes = hexToBytes(data.backup.salt);
    var ivBytes = hexToBytes(data.backup.iv);
    var cipherHex = data.backup.encryptedMnemonic || data.backup.ciphertext;
    var ctBytes = hexToBytes(cipherHex);
    var tagBytes = null;
    try {
      if (data.backup.authTag) tagBytes = hexToBytes(data.backup.authTag);
    } catch (_) {}

    var keyMaterial = await crypto.subtle.importKey('raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveBits']);
    var keyBits = await crypto.subtle.deriveBits({ name: 'PBKDF2', salt: saltBytes, iterations: 100000, hash: 'SHA-256' }, keyMaterial, 256);
    var aesKey = await crypto.subtle.importKey('raw', keyBits, 'AES-GCM', false, ['decrypt']);

    var candidates = [ctBytes];
    if (tagBytes && tagBytes.length > 0) {
      candidates.push(concatBytes(ctBytes, tagBytes));
      candidates.push(concatBytes(tagBytes, ctBytes));
    }

    for (var i = 0; i < candidates.length; i++) {
      try {
        var pt = await crypto.subtle.decrypt({ name: 'AES-GCM', iv: ivBytes, tagLength: 128 }, aesKey, candidates[i]);
        return new TextDecoder().decode(pt);
      } catch (_) {}
    }

    throw new Error('钱包密码错误');
  }

  async function broadcast(hex) {
    var res = await window.SCASH.request('/api/wallet/broadcast', {
      method: 'POST',
      body: JSON.stringify({ hex: hex }),
    });
    return res.txid;
  }

  async function buildSingleTx(mnemonic, utxos, outputs, feeSat, network) {
    var seed = bip39.mnemonicToSeedSync(mnemonic);
    var rootKey = HDKey.fromMasterSeed(seed);
    var childKey = rootKey.derive("m/84'/0'/0'/0/0");
    var myAddress = deriveScashAddress(mnemonic);

    var privKey = childKey.privateKey;
    var pubKey = childKey.publicKey;
    if (!privKey || !pubKey) throw new Error('无法派生签名密钥');

    var psbt = new bitcoin.Psbt({ network: network });
    var totalInputSat = 0n;
    var selectedUtxos = [];
    var outputsTotalSat = outputs.reduce(function (s, o) { return s + BigInt(o.value || 0); }, 0n);

    for (var i = 0; i < utxos.length; i++) {
      var u = utxos[i];
      if (!u || !u.txid || typeof u.vout !== 'number' || !u.amount) continue;
      var uSat = BigInt(Math.round(parseFloat(u.amount) * 1e8));
      var script = bitcoin.address.toOutputScript(myAddress, network);
      psbt.addInput({
        hash: u.txid,
        index: u.vout,
        witnessUtxo: {
          script: script,
          value: Number(uSat),
        },
      });
      selectedUtxos.push(uSat);
      totalInputSat += uSat;
      if (totalInputSat >= outputsTotalSat + feeSat) break;
    }

    if (totalInputSat < outputsTotalSat + feeSat) {
      throw new Error('UTXO 余额不足（含手续费）');
    }

    for (var j = 0; j < outputs.length; j++) {
      psbt.addOutput({ address: outputs[j].address, value: Number(outputs[j].value) });
    }

    var changeSat = totalInputSat - outputsTotalSat - feeSat;
    if (changeSat > 0n) {
      psbt.addOutput({ address: myAddress, value: Number(changeSat) });
    }

    var signer = {
      publicKey: Buffer.from(pubKey),
      sign: async function (hash) {
        var sig = await secp.sign(new Uint8Array(hash), privKey);
        return Buffer.from(toBytes(sig));
      },
    };

    for (var k = 0; k < selectedUtxos.length; k++) {
      await psbt.signInputAsync(k, signer);
    }

    psbt.finalizeAllInputs();
    return psbt.extractTransaction().toHex();
  }

  // --- Modal helpers ---
  function showConfirmModal() {
    return new Promise(function (resolve) {
      var modal = document.getElementById('confirmModal');
      modal.classList.remove('hidden');
      function cleanup(val) {
        modal.classList.add('hidden');
        document.getElementById('confirmOk').removeEventListener('click', onOk);
        document.getElementById('confirmCancel').removeEventListener('click', onCancel);
        resolve(val);
      }
      function onOk() { cleanup(true); }
      function onCancel() { cleanup(false); }
      document.getElementById('confirmOk').addEventListener('click', onOk);
      document.getElementById('confirmCancel').addEventListener('click', onCancel);
    });
  }

  function showPasswordModal(initError, validateCb) {
    return new Promise(function (resolve) {
      var modal = document.getElementById('pwModal');
      var input = document.getElementById('pwInput');
      var errEl = document.getElementById('pwError');
      var okBtn = document.getElementById('pwOk');
      
      input.value = '';
      okBtn.disabled = false;
      okBtn.textContent = '确认交易';
      errEl.textContent = initError || '';
      
      modal.classList.remove('hidden');
      setTimeout(function () { input.focus(); }, 100);
      
      function cleanup() {
        modal.classList.add('hidden');
        okBtn.removeEventListener('click', onOk);
        document.getElementById('pwCancel').removeEventListener('click', onCancel);
        input.removeEventListener('keydown', onKey);
      }
      
      async function onOk() {
        var val = input.value || '';
        if (!val) {
          errEl.textContent = '请输入密码';
          return;
        }
        
        okBtn.disabled = true;
        okBtn.innerHTML = '<span class="spinner"></span>验证中…';
        
        if (validateCb) {
          var isValid = await validateCb(val);
          if (isValid === true) {
            cleanup();
            resolve(val);
          } else {
            okBtn.disabled = false;
            okBtn.textContent = '确认交易';
            errEl.textContent = typeof isValid === 'string' ? isValid : '密码错误，请重新输入';
            if (isValid === 'TOO_MANY_ERRORS') {
              cleanup();
              resolve(null);
            }
          }
        } else {
          cleanup();
          resolve(val);
        }
      }
      
      function onCancel() { 
        cleanup(); 
        resolve(null); 
      }
      
      function onKey(e) { if (e.key === 'Enter') onOk(); }
      
      okBtn.addEventListener('click', onOk);
      document.getElementById('pwCancel').addEventListener('click', onCancel);
      input.addEventListener('keydown', onKey);
    });
  }

