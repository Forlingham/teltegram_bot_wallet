      </div>
      <div class="flex justify-between items-center">
        <span class="font-label text-[10px] text-on-surface-variant">链上手续费</span>
        <span id="estFee" class="font-label text-[10px] font-medium text-on-surface">-</span>
      </div>
      <div class="flex justify-between items-center">
        <span class="font-label text-[10px] text-on-surface-variant">应用手续费</span>
        <span id="estArrFee" class="font-label text-[10px] font-medium text-on-surface">-</span>
      </div>
      <div class="flex justify-between items-center">
        <span class="font-label text-[10px] text-on-surface-variant">DAP 上链</span>
        <span id="estDap" class="font-label text-[10px] font-medium text-on-surface">计算中…</span>
      </div>
      <div class="pt-2 mt-1 border-t border-outline-variant/10 flex justify-between items-baseline">
        <span class="font-headline text-xs font-bold text-on-surface">预计总支出</span>
        <span id="estTotal" class="font-headline text-base font-black text-primary">-</span>
      </div>
    </div>
  </section>
  
