<style>
  :root {
    --cover-bg: linear-gradient(135deg, #d42828 0%, #b81f1f 100%);
    --cover-flap: linear-gradient(180deg, #db3030 0%, #c42626 100%);
    --cover-back: #a81c1c;
    --inner-bg: #fffdf5;
    --text-main: #ffffff;
    --text-sub: rgba(255, 255, 255, 0.82);
    --glow-color: 212, 40, 40;
  }
  body { background: radial-gradient(circle at center, #4a0a0a 0%, #0f0f13 100%); }
  .scene { min-height: calc(100vh - 120px); display:flex; align-items:center; justify-content:center; padding-top:0; }
  .perspective-container { perspective: 1500px; width:100%; display:flex; justify-content:center; }
  .env-wrapper { position:relative; width:84vw; max-width:316px; height:66vh; max-height:450px; transform-style:preserve-3d; transform:rotateX(5deg) translateY(0); transition:transform .6s cubic-bezier(.34,1.56,.64,1); }
  .env-wrapper.settled { height:58vh; max-height:390px; }
  .env-back { position:absolute; inset:0; background:var(--cover-back); border-radius:12px; z-index:1; box-shadow:inset 0 0 40px rgba(0,0,0,.3); }
  .env-letter { position:absolute; bottom:15px; left:15px; right:15px; top:15px; background:var(--inner-bg); border-radius:8px; z-index:2; transition:transform .8s cubic-bezier(.34,1.56,.64,1) .5s, box-shadow .8s .5s; box-shadow:0 4px 12px rgba(0,0,0,.1); display:flex; flex-direction:column; align-items:center; padding:22px 18px; text-align:center; background-image:repeating-linear-gradient(45deg, transparent, transparent 10px, rgba(212,40,40,.04) 10px, rgba(212,40,40,.04) 20px); }
  .env-front { position:absolute; bottom:0; left:0; right:0; height:75%; background:var(--cover-bg); border-radius:0 0 12px 12px; z-index:3; box-shadow:0 -5px 20px rgba(0,0,0,.25); border-top:1px solid rgba(255,255,255,.15); }
  .env-flap { position:absolute; top:0; left:0; right:0; height:42%; background:var(--cover-flap); border-radius:12px 12px 50% 50%/12px 12px 35% 35%; transform-origin:top center; z-index:4; box-shadow:0 8px 20px rgba(0,0,0,.2); transition:transform .6s cubic-bezier(.4,0,.2,1), z-index 0s .3s; border-bottom:2px solid rgba(255,255,255,.2); }
  .sender-info { transition:opacity .3s ease; }
  .env-wrapper.open .sender-info { opacity:0; pointer-events:none; }
  .env-coin { position:absolute; top:42%; left:50%; transform:translate(-50%,-50%); width:92px; height:92px; background:#fff; border-radius:50%; border:1px solid rgba(0,0,0,.05); z-index:10; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:transform .4s cubic-bezier(.175,.885,.32,1.275); box-shadow:0 8px 24px rgba(0,0,0,.15), inset 0 4px 6px rgba(255,255,255,1), inset 0 -2px 6px rgba(0,0,0,.05), 0 0 20px rgba(var(--glow-color), .5); animation:coin-pulse 2s infinite alternate ease-in-out; -webkit-tap-highlight-color:transparent; touch-action:manipulation; }
  .env-coin.loading { pointer-events:none!important; animation:none!important; }
  .env-coin.loading .coin-inner img { animation:logo-spin .9s linear infinite; }
  @keyframes logo-spin { 0% { transform:rotate(0deg); } 100% { transform:rotate(360deg); } }
  @keyframes coin-pulse { 0% { box-shadow:0 8px 24px rgba(0,0,0,.15), inset 0 4px 6px rgba(255,255,255,1), inset 0 -2px 6px rgba(0,0,0,.05), 0 0 10px rgba(var(--glow-color), .2);} 100% { box-shadow:0 8px 24px rgba(0,0,0,.15), inset 0 4px 6px rgba(255,255,255,1), inset 0 -2px 6px rgba(0,0,0,.05), 0 0 34px rgba(var(--glow-color), .8);} }
  .coin-inner { position:relative; width:78px; height:78px; border-radius:50%; overflow:hidden; box-shadow:inset 0 2px 4px rgba(0,0,0,.1); background:#fff; pointer-events:none; }
  .coin-inner img { width:100%; height:100%; object-fit:cover; pointer-events:none; }
  .coin-reflection { position:absolute; inset:0; border-radius:50%; background:linear-gradient(135deg, rgba(255,255,255,.7) 0%, rgba(255,255,255,0) 45%, rgba(0,0,0,.1) 100%); pointer-events:none; }
  .env-wrapper.open { transform:rotateX(0deg) translateY(2vh); }
  .env-wrapper.open .env-flap { transform:rotateX(180deg); z-index:1; }
  .env-wrapper.open .env-letter { transform:translateY(-28%); box-shadow:0 15px 30px rgba(0,0,0,.3); z-index:5; }
  .env-wrapper.open .env-coin { animation:none!important; transform:translate(-50%,-50%) scale(0)!important; opacity:0; pointer-events:none; }
  .tone-main { color: var(--text-main); }
  .tone-sub { color: var(--text-sub); }
  .status-tip { margin-top:10px; font-size:12px; color:rgba(255,255,255,.85); text-align:center; }
  .home-btn { position:fixed; top:14px; left:14px; z-index:60; min-width:36px; height:36px; padding:0 10px; border-radius:999px; border:1px solid rgba(255,255,255,.28); background:rgba(0,0,0,.28); color:#fff; font-size:13px; font-weight:700; line-height:34px; text-align:center; cursor:pointer; }
  .close-btn { position:fixed; top:14px; right:14px; z-index:60; width:36px; height:36px; border-radius:999px; border:1px solid rgba(255,255,255,.28); background:rgba(0,0,0,.28); color:#fff; font-size:22px; line-height:1; cursor:pointer; }
  .claim-list { margin:12px auto 0; width:84vw; max-width:316px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.12); border-radius:12px; padding:8px 10px; }
  .claim-row { display:flex; align-items:center; justify-content:space-between; gap:8px; padding:6px 0; border-bottom:1px dashed rgba(255,255,255,.12); }
  .claim-row:last-child { border-bottom:none; }
  .claim-user { display:flex; align-items:center; gap:8px; min-width:0; }
  .claim-avatar { width:24px; height:24px; border-radius:999px; object-fit:cover; border:1px solid rgba(255,255,255,.22); background:#fff; }
  .claim-name { color:#f3f4f6; font-size:12px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:160px; }
  .claim-amount { color:#fde68a; font-size:12px; font-weight:700; white-space:nowrap; }
  .amount-main { display:flex; align-items:flex-end; justify-content:center; gap:6px; }
  .amount-int { font-size:44px; font-weight:900; color:#dc2626; line-height:1; }
  .amount-decimal { font-size:22px; font-weight:800; color:#dc2626; line-height:1.05; }
  .amount-logo { width:20px; height:20px; object-fit:contain; margin-bottom:5px; }
  .result-hint { display:none; margin-top:6px; font-size:14px; font-weight:700; color:#9b1c1c; }
</style>

<button id="closeBtn" class="close-btn" title="关闭">×</button>
<button id="homeBtn" class="home-btn" title="回到首页">首页</button>

<div id="loadingSection" class="card" style="text-align:center; padding:40px;">
  <div style="color:var(--muted);">加载中…</div>
</div>

<div id="errorSection" class="card" style="display:none; text-align:center;">
  <div id="errorMsg" style="color:#c0392b; font-size:14px;"></div>
  <a href="/wallet/redpacket" class="btn btn-brand" style="margin-top:16px; display:inline-block; text-decoration:none;">返回红包</a>
</div>

<div id="packetSection" style="display:none;">
  <div class="scene">
    <div class="perspective-container">
      <div class="env-wrapper" id="envelope">
        <div class="env-back" id="coverBack"></div>
        <div class="env-letter">
          <div class="flex flex-col items-center w-full mt-2">
            <img id="senderAvatar" src="https://api.dicebear.com/7.x/avataaars/svg?seed=TG" alt="Avatar" class="w-12 h-12 rounded-full border-2 border-red-100 mb-1 bg-white shadow-sm z-10" style="width:48px;height:48px;border-radius:999px;border:2px solid #fee2e2;" />
            <p class="text-gray-500 text-xs mb-1" id="packetSender" style="font-size:12px;color:#6b7280;margin:4px 0;">来自 - 的红包</p>
            <h2 id="packetMessage" style="font-size:22px; font-weight:800; color:#dc2626; margin-top:6px; letter-spacing:.06em;">恭喜发财，大吉大利</h2>
          </div>
          <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; width:100%;">
            <div id="packetAmount" class="amount-main" style="margin-bottom:4px;"><span class="amount-int">-</span></div>
            <div id="fiatAmount" style="font-size:12px; color:rgba(0,0,0,.65); margin-bottom:8px; display:none; font-weight:600;"></div>
            <div id="resultHint" class="result-hint"></div>
          </div>
          <div id="claimStatus" style="display:block; padding-top:10px; border-top:1px dashed #fca5a5; width:100%; text-align:center; font-size:13px; color:#6b7280;"></div>
        </div>
        <div class="env-front">
          <div style="position:absolute; bottom:24px; left:50%; transform:translateX(-50%); width:100%; text-align:center; opacity:.58;">
            <div class="tone-sub" style="font-size:11px; letter-spacing:.2em; font-weight:500;">POWERED BY SCASH</div>
          </div>
        </div>
        <div class="env-flap" id="coverFlap" style="display:flex; flex-direction:column; align-items:center; padding-top:24px;">
          <div class="sender-info" style="display:flex; flex-direction:column; align-items:center;">
            <img id="senderAvatarTop" src="https://api.dicebear.com/7.x/avataaars/svg?seed=TG" alt="Avatar" style="width:48px;height:48px;border-radius:999px;border:2px solid #fff;box-shadow:0 4px 12px rgba(0,0,0,.25);margin-bottom:6px;" />
            <span class="tone-main" id="senderNameTop" style="font-size:14px; font-weight:700;">@TelegramUser</span>
            <span class="tone-sub" style="font-size:12px; margin-top:2px;">给你发了一个红包</span>
          </div>
        </div>
        <div class="env-coin" id="coin">
          <div class="coin-inner">
            <img src="/img/logo-256x256.png" alt="Open" />
            <div class="coin-reflection"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="claimList" class="claim-list" style="display:none;">
  <div id="claimListInner"></div>
</div>

<script>
  var claimContext = { canClaim: false, alreadyClaimed: false };

  function formatAmountWithLogo(amount) {
    var v = (amount || '0').toString();
    var parts = v.split('.');
    var intPart = parts[0] || '0';
    var decPart = parts[1] || '00000000';
    var shortDec = '.' + decPart.slice(0, 4);
    return '<span class="amount-int">' + intPart + '</span><span class="amount-decimal">' + shortDec + '</span><img class="amount-logo" src="/img/logo-128x128.png" alt="SCASH" />';
  }

  function renderClaimList(claims) {
    var list = document.getElementById('claimList');
    var inner = document.getElementById('claimListInner');
    if (!claims || claims.length === 0) {
      list.style.display = 'none';
      inner.innerHTML = '';
      return;
    }

    inner.innerHTML = claims.slice(0, 8).map(function (c) {
      var user = c.user || {};
      var name = user.username ? ('@' + user.username) : (user.telegramId ? ('#' + user.telegramId) : '匿名用户');
      var avatar = user.photoUrl || ('https://api.dicebear.com/7.x/avataaars/svg?seed=' + encodeURIComponent(name));
      return '<div class="claim-row">' +
        '<div class="claim-user">' +
          '<img class="claim-avatar" src="' + avatar + '" alt="avatar" />' +
          '<div class="claim-name">' + name + '</div>' +
        '</div>' +
        '<div class="claim-amount">' + (c.amount || '0') + ' SCASH</div>' +
      '</div>';
    }).join('');
    list.style.display = 'block';
  }

  function getQueryParam(name) {
    var params = new URL(location.href).searchParams;
    return params.get(name) || '';
  }

  function resolvePacketHash() {
    var packet = getQueryParam('packet');
    if (packet) return packet;

    var tg = window.SCASH && window.SCASH.TG;
    var startParam = '';

    if (tg && tg.initDataUnsafe && tg.initDataUnsafe.start_param) {
      startParam = tg.initDataUnsafe.start_param;
    }

    if (!startParam) {
      startParam = getQueryParam('startapp') || getQueryParam('start_param') || '';
    }

    if (startParam.indexOf('rp_') === 0) {
      return startParam.slice(3);
    }

    return '';
  }

  function showError(msg) {
    document.getElementById('loadingSection').style.display = 'none';
    document.getElementById('errorSection').style.display = 'block';
    document.getElementById('errorMsg').textContent = msg;
  }

  function showFiatValue(amountStr) {
    var fiatEl = document.getElementById('fiatAmount');
    var pd = window.SCASH.priceData;
    if (!pd || !pd.price || !amountStr) {
      fiatEl.style.display = 'none';
      return;
    }
    var priceUsd = parseFloat(pd.price.price || 0);
    var amount = parseFloat(amountStr);
    if (!priceUsd || !amount || amount <= 0) {
      fiatEl.style.display = 'none';
      return;
    }
    fiatEl.style.color = 'rgba(0,0,0,0.65)';
    fiatEl.textContent = '\u2248 $' + (amount * priceUsd).toFixed(2) + ' USD';
    fiatEl.style.display = 'block';
  }

  function showPacket(data) {
    var packet = data && data.redPacket ? data.redPacket : (data || {});
    var hasClaimed = typeof data.hasClaimed === 'boolean' ? data.hasClaimed : !!packet.hasClaimed;
    var claimedAmount = data.claimedAmount || packet.claimedAmount || '';
    var senderUsername = data.senderUsername || packet.senderUsername || (packet.sender && packet.sender.username) || '';
    var senderTelegramId = data.senderTelegramId || packet.senderTelegramId || (packet.sender && packet.sender.telegramId) || '';

    document.getElementById('loadingSection').style.display = 'none';
    document.getElementById('packetSection').style.display = 'block';

    document.getElementById('packetMessage').textContent = packet.message || '恭喜发财，大吉大利';
    var senderLabel = (senderUsername || senderTelegramId || '神秘好友');
    document.getElementById('packetSender').textContent = '来自 @' + senderLabel + ' 的红包';
    document.getElementById('senderNameTop').textContent = '@' + senderLabel;
    var senderPhoto = (packet.sender && packet.sender.photoUrl) || null;
    if (senderPhoto) {
      document.getElementById('senderAvatar').src = senderPhoto;
      document.getElementById('senderAvatarTop').src = senderPhoto;
    }
    var amountEl = document.getElementById('packetAmount');
    var claimStatus = document.getElementById('claimStatus');
    amountEl.innerHTML = '<span class="amount-int">-</span>';
    claimStatus.textContent = '总金额 ' + (packet.totalAmount || '0') + ' SCASH · 共 ' + (packet.count || 0) + ' 个';
    renderClaimList(data.claims || packet.claims || []);

    var cover = packet.cover || {};
    if (cover.imageUrl) {
      document.getElementById('coverBack').style.backgroundImage = 'url(' + cover.imageUrl + ')';
      document.getElementById('coverFlap').style.backgroundImage = 'url(' + cover.imageUrl + ')';
      document.getElementById('coverFlap').style.backgroundPosition = 'center top';
      document.getElementById('coverBack').style.backgroundPosition = 'center';
      document.getElementById('coverFlap').style.backgroundSize = 'cover';
      document.getElementById('coverBack').style.backgroundSize = 'cover';
    }

    var textTone = (cover.textTone || 'LIGHT').toUpperCase();
    if (textTone === 'DARK') {
      document.documentElement.style.setProperty('--text-main', '#111827');
      document.documentElement.style.setProperty('--text-sub', 'rgba(17,24,39,0.72)');
      document.documentElement.style.setProperty('--glow-color', '99, 102, 241');
    } else {
      document.documentElement.style.setProperty('--text-main', '#ffffff');
      document.documentElement.style.setProperty('--text-sub', 'rgba(255,255,255,0.82)');
      document.documentElement.style.setProperty('--glow-color', '212, 40, 40');
    }

    claimContext.canClaim = packet.status === 'ACTIVE' && !hasClaimed;
    claimContext.alreadyClaimed = hasClaimed;

    var coin = document.getElementById('coin');
    var wrapper = document.getElementById('envelope');
    var hintEl = document.getElementById('resultHint');
    hintEl.style.display = 'none';
    hintEl.textContent = '';
    document.getElementById('fiatAmount').style.display = 'none';
    
    if (packet.status === 'ACTIVE' && !hasClaimed) {
      coin.style.pointerEvents = 'auto';
      wrapper.classList.remove('open');
      wrapper.classList.remove('settled');
    } else if (hasClaimed) {
      amountEl.innerHTML = formatAmountWithLogo(claimedAmount || '0');
      showFiatValue(claimedAmount || '0');
      wrapper.classList.add('open');
      wrapper.classList.add('settled');
      coin.style.pointerEvents = 'none';
      hintEl.style.display = 'block';
      hintEl.textContent = '你已领取';
    } else if (packet.status === 'EXPIRED') {
      wrapper.classList.add('open');
      wrapper.classList.add('settled');
      coin.style.pointerEvents = 'none';
      hintEl.style.display = 'block';
      hintEl.textContent = '红包已过期';
    } else if (packet.status === 'COMPLETED' || Number(packet.remainingCount || 0) <= 0) {
      wrapper.classList.add('open');
      wrapper.classList.add('settled');
      coin.style.pointerEvents = 'none';
      hintEl.style.display = 'block';
      hintEl.textContent = '红包已被抢完';
    } else {
      wrapper.classList.add('open');
      wrapper.classList.add('settled');
      coin.style.pointerEvents = 'none';
      hintEl.style.display = 'block';
      hintEl.textContent = '红包已结束';
    }
  }

  async function loadPacket() {
    var packetHash = resolvePacketHash();
    if (!packetHash) { showError('红包参数缺失，请通过分享链接打开'); return; }

    try {
      var data = await window.SCASH.request('/api/redpacket/' + encodeURIComponent(packetHash));
      showPacket(data);
    } catch (e) {
      showError(e.message || '红包不存在或已过期');
    }
  }

  async function claimPacket() {
    var coin = document.getElementById('coin');
    var wrapper = document.getElementById('envelope');
    var hintEl = document.getElementById('resultHint');
    var packetHash = resolvePacketHash();
    if (!packetHash) return;

    coin.classList.add('loading');
    coin.style.pointerEvents = 'none';

    try {
      var result = await window.SCASH.request('/api/redpacket/' + encodeURIComponent(packetHash) + '/claim', {
        method: 'POST',
        body: JSON.stringify({}),
      });

      coin.classList.remove('loading');
      wrapper.classList.add('open');
      setTimeout(function () { wrapper.classList.add('settled'); }, 600);
      document.getElementById('packetAmount').innerHTML = formatAmountWithLogo(result.amount || '0');
      showFiatValue(result.amount || '0');
      hintEl.style.display = 'block';
      hintEl.textContent = '领取成功';

      if (result.claims) {
        renderClaimList(result.claims);
      }
    } catch (e) {
      coin.classList.remove('loading');
      // 重新拉取红包最新状态，复用 showPacket 展示过期/抢完等信息
      try {
        var data = await window.SCASH.request('/api/redpacket/' + encodeURIComponent(packetHash));
        showPacket(data);
      } catch (_) {
        coin.style.pointerEvents = 'auto';
        alert((e && e.message) || '领取失败');
      }
    }
  }

  document.getElementById('coin').addEventListener('click', function () {
    if (!claimContext.canClaim) return;
    claimPacket();
  });

  function closeMiniApp() {
    var tg = window.SCASH && window.SCASH.TG;
    if (tg && typeof tg.close === 'function') {
      tg.close();
      return;
    }
    location.href = '/wallet/redpacket';
  }

  document.getElementById('closeBtn').addEventListener('click', function () {
    closeMiniApp();
  });

  document.getElementById('homeBtn').addEventListener('click', function () {
    location.href = '/wallet';
  });

  (function bindBackAsClose() {
    var tg = window.SCASH && window.SCASH.TG;
    if (tg) {
      try { tg.BackButton.show(); } catch (_) {}
      tg.onEvent('backButtonClicked', function () {
        closeMiniApp();
      });
    }

    // Android system back: consume one history step and close Mini App
    if (!history.state || !history.state.__claimBackClose) {
      history.pushState({ __claimBackClose: true }, '', location.href);
    }
    window.addEventListener('popstate', function () {
      closeMiniApp();
    });
  })();

  loadPacket();
</script>
