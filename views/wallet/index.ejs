<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
      :root {
        --bg: #f4f8f1;
        --panel: #ffffff;
        --text: #1e2a1e;
        --muted: #5e695e;
        --line: #d6e1d2;
        --brand: #2f7a42;
        --warn-bg: #fff1df;
        --warn-text: #a95a08;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--bg); color: var(--text); font-family: "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif; }
      .app { max-width: 860px; margin: 0 auto; padding: 16px 16px 88px; }
      .app-header { padding: 14px 4px 12px; }
      .brand { font-size: 24px; font-weight: 700; }
      .subtitle { margin-top: 4px; color: var(--muted); font-size: 13px; }
      .card { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 14px; margin-bottom: 12px; }
      .label { color: var(--muted); font-size: 13px; }
      .value { font-size: 18px; font-weight: 700; margin-top: 6px; }
      .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; word-break: break-all; font-size: 13px; }
      .warn { background: var(--warn-bg); border-color: #f1ce9c; }
      .warn-title { margin: 0; color: var(--warn-text); font-weight: 700; }
      .warn-desc { margin: 8px 0 12px; font-size: 14px; line-height: 1.5; }
      .row { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
      .btn { border: none; border-radius: 10px; padding: 10px 12px; font-weight: 600; cursor: pointer; }
      .btn-brand { background: var(--brand); color: #fff; }
      .btn-soft { background: #e6f3ea; color: var(--brand); }
      .actions { display: flex; gap: 8px; flex-wrap: wrap; }
      .quick-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
      .quick-link { display: block; text-align: center; text-decoration: none; color: var(--brand); background: #edf7ef; border: 1px solid #d7eadb; border-radius: 10px; padding: 10px 8px; font-weight: 600; font-size: 14px; }
      .bottom-nav { position: fixed; left: 0; right: 0; bottom: 0; display: grid; grid-template-columns: repeat(4, 1fr); background: #ffffff; border-top: 1px solid var(--line); }
      .nav-item { padding: 12px 8px 14px; text-align: center; text-decoration: none; color: #5f695f; font-size: 13px; }
      .nav-item.active { color: var(--brand); font-weight: 700; }
    </style>
  </head>
  <body>
    <main class="app">
      <%- include('../partials/header') %>

      <section id="walletMissing" class="card" style="display: none">
        <div style="font-weight:700;margin-bottom:8px;">还没有钱包</div>
        <div class="label" style="margin-bottom: 12px;">请选择一个方式开始：创建新钱包、导入助记词钱包或绑定观察钱包。</div>
        <div class="quick-grid">
          <a class="quick-link" href="/wallet/create">创建钱包</a>
          <a class="quick-link" href="/wallet/import">导入钱包</a>
          <a class="quick-link" href="/wallet/bind">绑定观察钱包</a>
        </div>
      </section>

      <section id="walletMain" style="display: none">
        <section id="backupReminder" class="card warn" style="display: none">
          <p class="warn-title">请尽快备份助记词</p>
          <p class="warn-desc">你尚未完成助记词备份。未备份前此提醒会持续显示，请尽快备份防止资产无法恢复。</p>
          <div class="actions">
            <button id="btnBackupDone" class="btn btn-brand">我已备份</button>
            <a href="/wallet/recover" class="quick-link" style="padding:10px 12px;">去恢复页查看密文</a>
          </div>
        </section>

        <section class="card">
          <div class="label">钱包地址</div>
          <div id="walletAddress" class="value mono">-</div>
        </section>

        <section class="card">
          <div class="row">
            <div>
              <div class="label">可用余额</div>
              <div id="walletBalance" class="value">0.00000000 SCASH</div>
            </div>
            <button id="btnRefresh" class="btn btn-soft">刷新</button>
          </div>
        </section>
      </section>
    </main>

    <%- include('../partials/bottom-nav') %>

    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
      (function () {
        const enabled = new URL(window.location.href).searchParams.get('debug') === '1' || localStorage.getItem('DEBUG_CONSOLE') === '1';
        if (!enabled) return;
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/eruda';
        script.onload = function () { window.eruda && window.eruda.init(); };
        document.head.appendChild(script);
      })();
    </script>
    <script>
      const SESSION_KEY = 'SCASH_SESSION_TOKEN';
      function getSessionToken() { return localStorage.getItem(SESSION_KEY) || ''; }

      function readInitData() {
        if (window.Telegram && window.Telegram.WebApp) {
          window.Telegram.WebApp.ready();
          const fromSdk = window.Telegram.WebApp.initData || '';
          if (fromSdk) return fromSdk;
        }
        const url = new URL(window.location.href);
        return url.searchParams.get('tgWebAppData') || '';
      }

      async function ensureSession() {
        const existing = getSessionToken();
        if (existing) return existing;
        const initData = readInitData();
        if (!initData) throw new Error('未检测到 Telegram 会话，请从机器人 Mini App 打开');

        const res = await fetch('/api/auth/telegram/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ initData }),
        });
        const json = await res.json();
        if (!res.ok || !json.success) throw new Error((json.error && json.error.message) || '登录失败');
        localStorage.setItem(SESSION_KEY, json.data.sessionToken);
        return json.data.sessionToken;
      }

      async function request(path, options = {}) {
        const token = await ensureSession();
        const res = await fetch(path, {
          ...options,
          headers: {
            'Content-Type': 'application/json',
            'x-session-token': token,
            ...(options.headers || {}),
          },
        });
        const json = await res.json();
        if (!res.ok || !json.success) throw new Error((json.error && json.error.message) || '请求失败');
        return json.data;
      }

      async function loadHome() {
        const home = await request('/api/wallet/home');
        if (!home.hasWallet) {
          document.getElementById('walletMissing').style.display = 'block';
          document.getElementById('walletMain').style.display = 'none';
          return;
        }

        document.getElementById('walletMissing').style.display = 'none';
        document.getElementById('walletMain').style.display = 'block';
        document.getElementById('walletAddress').textContent = home.address || '-';
        document.getElementById('backupReminder').style.display = home.showBackupReminder ? 'block' : 'none';
      }

      async function loadBalance() {
        const balance = await request('/api/wallet/balance');
        document.getElementById('walletBalance').textContent = `${balance.balance} SCASH`;
      }

      document.getElementById('btnRefresh').addEventListener('click', async () => {
        try { await loadBalance(); } catch (e) { alert(e.message); }
      });

      document.getElementById('btnBackupDone').addEventListener('click', async () => {
        try {
          await request('/api/wallet/backup/complete', {
            method: 'POST',
            body: JSON.stringify({ backedUp: true }),
          });
          await loadHome();
        } catch (e) {
          alert(e.message);
        }
      });

      (async () => {
        try {
          await loadHome();
          const main = document.getElementById('walletMain');
          if (main.style.display !== 'none') await loadBalance();
        } catch (e) {
          alert(`初始化失败：${e.message}`);
        }
      })();
    </script>
  </body>
  </html>
