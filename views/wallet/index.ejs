        <div class="w-full h-[1px] bg-outline-variant absolute top-1/4"></div>
        <div class="w-full h-[1px] bg-outline-variant absolute top-2/4"></div>
        <div class="w-full h-[1px] bg-outline-variant absolute top-3/4"></div>
      </div>
