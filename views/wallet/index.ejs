<section id="walletMissing" class="card" style="display: none">
  <div style="font-weight:700;margin-bottom:8px;">还没有钱包</div>
  <div class="label" style="margin-bottom:12px;">请选择一个方式开始：创建新钱包、导入助记词钱包或绑定观察钱包。</div>
  <div class="quick-grid">
    <a class="quick-link" href="/wallet/create">创建钱包</a>
    <a class="quick-link" href="/wallet/import">导入钱包</a>
    <a class="quick-link" href="/wallet/bind">绑定观察钱包</a>
  </div>
</section>

<section id="walletMain" style="display: none">
  <section id="backupReminder" class="card warn" style="display: none">
    <p class="warn-title">请尽快备份助记词</p>
    <p class="warn-desc">你尚未完成助记词备份。未备份前此提醒会持续显示，请尽快备份防止资产无法恢复。</p>
    <div class="actions">
      <button id="btnBackupDone" class="btn btn-brand">我已备份</button>
      <a href="/wallet/recover" class="quick-link" style="padding:10px 12px;">去恢复页查看密文</a>
    </div>
  </section>

  <section class="card">
    <div class="label">钱包地址</div>
    <div id="walletAddress" class="value mono">-</div>
  </section>

  <section class="card">
    <div class="row">
      <div>
        <div class="label">可用余额</div>
        <div id="walletBalance" class="value">0.00000000 SCASH</div>
      </div>
      <button id="btnRefresh" class="btn btn-soft">刷新</button>
    </div>
  </section>
</section>

<script>
  async function loadHome() {
    const home = await window.SCASH.request('/api/wallet/home');
    if (!home.hasWallet) {
      document.getElementById('walletMissing').style.display = 'block';
      document.getElementById('walletMain').style.display = 'none';
      return;
    }
    document.getElementById('walletMissing').style.display = 'none';
    document.getElementById('walletMain').style.display = 'block';
    document.getElementById('walletAddress').textContent = home.address || '-';
    document.getElementById('backupReminder').style.display = home.showBackupReminder ? 'block' : 'none';
  }

  async function loadBalance() {
    const balance = await window.SCASH.request('/api/wallet/balance');
    document.getElementById('walletBalance').textContent = balance.balance + ' SCASH';
  }

  document.getElementById('btnRefresh').addEventListener('click', async function () {
    try { await loadBalance(); } catch (e) { alert(e.message); }
  });

  document.getElementById('btnBackupDone').addEventListener('click', async function () {
    try {
      await window.SCASH.request('/api/wallet/backup/complete', {
        method: 'POST',
        body: JSON.stringify({ backedUp: true }),
      });
      await loadHome();
    } catch (e) { alert(e.message); }
  });

  (async function () {
    try {
      await loadHome();
      var main = document.getElementById('walletMain');
      if (main.style.display !== 'none') await loadBalance();
    } catch (e) { alert('初始化失败：' + e.message); }
  })();
</script>