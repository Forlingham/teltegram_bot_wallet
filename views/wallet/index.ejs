<section id="noWallet" class="card" style="display: none">
  <div style="text-align:center; padding: 24px 0 8px;">
    <div style="font-size:48px; margin-bottom:12px;">&#x1F3E6;</div>
    <div style="font-size:18px; font-weight:700; margin-bottom:6px;">欢迎使用 SCASH 钱包</div>
    <div class="label" style="margin-bottom:24px;">创建、导入或绑定钱包后即可开始使用</div>
  </div>
  
  <div id="pendingAirdropSection" style="display: none; background: #fffdf5; border: 1px dashed #f1ce9c; border-radius: 12px; padding: 16px; margin-bottom: 24px; text-align: center;">
    <div style="font-size: 14px; color: #a95a08; font-weight: 700; margin-bottom: 8px;">&#x1F381; 你有待入账的红包资金</div>
    <div style="font-size: 28px; font-weight: 900; color: #d42828; margin-bottom: 4px;">
      <span id="pendingAirdropAmount">-</span> <span style="font-size: 14px;">SCASH</span>
    </div>
    <div style="font-size: 12px; color: var(--muted); margin-bottom: 12px;">
      来自 <span id="pendingAirdropCount">-</span> 个红包。创建或导入钱包后将自动打入你的地址。
    </div>
  </div>

  <div class="quick-grid">
    <a class="quick-link" href="/wallet/create">&#x1F310; 创建钱包</a>
    <a class="quick-link" href="/wallet/import">&#x1F504; 导入钱包</a>
    <a class="quick-link" href="/wallet/bind">&#x1F517; 绑定钱包</a>
  </div>
</section>

<section id="walletHome" style="display: none">
  <div id="backupReminder" class="card warn" style="display: none; margin-bottom:12px;">
    <div class="warn-title">请尽快备份助记词</div>
    <div class="warn-desc">你尚未完成助记词备份，请尽快备份防止资产无法恢复。</div>
    <div class="actions">
      <button id="btnBackupDone" class="btn btn-brand">我已备份</button>
      <a href="/wallet/recover" class="quick-link" style="padding:10px 12px;">查看密文</a>
    </div>
  </div>

  <div class="card">
    <div class="label" style="display:flex; justify-content:space-between; align-items:center;">
      <span>钱包地址</span>
      <span id="watchOnlyTag" style="display:none; font-size:11px; padding:2px 6px; background:#f4f7f2; border:1px dashed #c0392b; color:#c0392b; border-radius:4px; font-weight:700;">观察钱包 (不可发送)</span>
    </div>
    <div id="walletAddress" class="mono" style="font-size:12px; word-break:break-all; color:var(--brand); margin-top:6px;">-</div>
  </div>

  <div class="card" style="padding: 20px 16px;">
    <div id="homeAvatarArea" style="display:none; text-align:center; margin-bottom:12px;">
      <img id="homeAvatar" src="" style="width:56px; height:56px; border-radius:50%; object-fit:cover; border:2px solid var(--brand);" />
    </div>
    <div class="row" style="align-items: flex-start; margin-bottom: 16px;">
      <div>
        <div class="label" style="margin-bottom:8px;">总余额</div>
        <div id="walletTotalBalance" class="value" style="font-size: 32px; color: var(--brand); margin-top: 0;">0.00000000</div>
        <div style="font-size: 13px; font-weight: 700; color: var(--brand);">SCASH</div>
        <div id="balanceFiat" style="display:none; font-size:12px; color:var(--muted); margin-top:4px;"></div>
      </div>
      <div style="text-align:right;">
        <button id="btnRefresh" class="btn btn-soft" style="padding: 8px 12px; margin-bottom:6px;">&#x21BB; 刷新</button>
        <div id="priceTag" style="display:none; font-size:11px; color:var(--muted); white-space:nowrap;"></div>
      </div>
    </div>
    
    <div style="background: #f8fbf7; border: 1px dashed #d8e8d8; border-radius: 10px; padding: 12px;">
      <div class="row" style="margin-bottom: 6px;">
        <span class="label" style="margin:0;">已确认 (链上)</span>
        <span id="walletConfirmedBalance" class="mono" style="font-weight: 600; color: #1e2a1e;">0.00000000 SCASH</span>
      </div>
      <div class="row">
        <span class="label" style="margin:0;">未确认 (内存池)</span>
        <span id="walletUnconfirmedBalance" class="mono" style="font-weight: 600; color: #a95a08;">0.00000000 SCASH</span>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="label" style="margin-bottom:10px;">常用操作</div>
    <div class="quick-grid">
      <a class="quick-link" href="/wallet/send">
        <div style="font-size:24px;">&#x2B06;</div>
        <div style="margin-top:4px;">发送</div>
      </a>
      <a class="quick-link" href="/wallet/receive">
        <div style="font-size:24px;">&#x2B07;</div>
        <div style="margin-top:4px;">接收</div>
      </a>
      <a class="quick-link" href="/wallet/inscribe">
        <div style="font-size:24px;">&#x270D;</div>
        <div style="margin-top:4px;">刻字上链</div>
      </a>
      <a id="scanQrHomeBtn" class="quick-link" href="javascript:void(0)">
        <div style="font-size:24px;">&#x1F4F7;</div>
        <div style="margin-top:4px;">扫码</div>
      </a>
    </div>
  </div>

  <div id="priceChartCard" class="card" style="display:none; padding:14px 14px 6px;">
    <div class="row" style="margin-bottom:8px; align-items:flex-start;">
      <div>
        <div class="label" style="margin:0 0 2px;">SCASH 7日走势</div>
        <div id="chartPriceChange" style="font-size:11px; font-weight:700;"></div>
      </div>
      <div style="text-align:right;">
        <div id="chartCurrentPrice" style="font-size:16px; font-weight:800; color:var(--brand);"></div>
        <div id="chartCrosshairPrice" style="font-size:11px; color:var(--muted); min-height:16px;"></div>
      </div>
    </div>
    <div id="priceChartContainer" style="width:100%; height:200px;"></div>
  </div>
</section>

<script src="https://unpkg.com/lightweight-charts@4.1.3/dist/lightweight-charts.standalone.production.js"></script>

<script>
  function satoshiToScashString(sats) {
    var sign = sats < 0n ? '-' : '';
    var abs = sats < 0n ? -sats : sats;
    var whole = abs / 100000000n;
    var frac = (abs % 100000000n).toString().padStart(8, '0');
    return sign + whole.toString() + '.' + frac;
  }

  async function loadHome() {
    try {
      var home = await window.SCASH.request('/api/wallet/home');
      if (!home.hasWallet) {
        document.getElementById('noWallet').style.display = 'block';
        document.getElementById('walletHome').style.display = 'none';
        
        if (home.pendingAirdrop) {
          document.getElementById('pendingAirdropAmount').textContent = home.pendingAirdrop.amount;
          document.getElementById('pendingAirdropCount').textContent = home.pendingAirdrop.count;
          document.getElementById('pendingAirdropSection').style.display = 'block';
        }
        
        return;
      }
      document.getElementById('noWallet').style.display = 'none';
      document.getElementById('walletHome').style.display = 'block';
      homeReady = true;
      document.getElementById('walletAddress').textContent = home.address || '-';
      
      if (home.avatarUrl) {
        document.getElementById('homeAvatar').src = home.avatarUrl;
        document.getElementById('homeAvatarArea').style.display = 'block';
      } else {
        document.getElementById('homeAvatarArea').style.display = 'none';
      }
      document.getElementById('backupReminder').style.display = home.showBackupReminder ? 'block' : 'none';
      
      if (home.isWatchOnly) {
        document.getElementById('watchOnlyTag').style.display = 'inline-block';
      }
      
      loadBalance();
    } catch (e) {
      alert('初始化失败：' + e.message);
    }
  }

  async function loadBalance() {
    var btn = document.getElementById('btnRefresh');
    btn.innerHTML = '<span class="spinner" style="border-color:var(--brand); border-top-color:transparent;"></span> 刷新中…';
    btn.disabled = true;
    
    try {
      var bal = await window.SCASH.request('/api/wallet/balance?includeUnconfirmed=true');
      var utxos = bal.utxos || [];
      var confirmedSats = 0n;
      var unconfirmedSats = 0n;
      
      for (var i = 0; i < utxos.length; i++) {
        var u = utxos[i];
        var uSat = BigInt(Math.round(parseFloat(u.amount) * 1e8));
        if (u.isUnconfirmed) {
          unconfirmedSats += uSat;
        } else {
          confirmedSats += uSat;
        }
      }
      
      var totalSats = confirmedSats + unconfirmedSats;
      cachedTotalSats = totalSats;
      
      document.getElementById('walletTotalBalance').textContent = satoshiToScashString(totalSats);
      document.getElementById('walletConfirmedBalance').textContent = satoshiToScashString(confirmedSats) + ' SCASH';
      document.getElementById('walletUnconfirmedBalance').textContent = satoshiToScashString(unconfirmedSats) + ' SCASH';
      
      updatePriceDisplay();
    } catch (e) {
      document.getElementById('walletTotalBalance').textContent = '获取失败';
      document.getElementById('walletConfirmedBalance').textContent = '-';
      document.getElementById('walletUnconfirmedBalance').textContent = '-';
    } finally {
      btn.innerHTML = '&#x21BB; 刷新';
      btn.disabled = false;
    }
  }

  document.getElementById('btnRefresh').addEventListener('click', function () {
    loadBalance();
  });

  document.getElementById('btnBackupDone').addEventListener('click', async function () {
    try {
      await window.SCASH.request('/api/wallet/backup/complete', {
        method: 'POST',
        body: JSON.stringify({ backedUp: true }),
      });
      document.getElementById('backupReminder').style.display = 'none';
    } catch (e) {
      alert(e.message);
    }
  });

  var cachedTotalSats = null;
  var homeReady = false;
  var lwChart = null;
  var lwSeries = null;

  function updatePriceDisplay() {
    var pd = window.SCASH.priceData;
    if (!pd || !pd.price) return;
    if (!homeReady) return;
    var priceUsd = parseFloat(pd.price.price || 0);
    if (!priceUsd) return;

    // 价格标签
    var priceTag = document.getElementById('priceTag');
    var pct24 = parseFloat(pd.price.changePercent24h || 0);
    var pctSign = pct24 >= 0 ? '+' : '';
    var pctColor = pct24 >= 0 ? '#2f7a42' : '#c0392b';
    priceTag.innerHTML = '$' + priceUsd.toFixed(6) + ' <span style="color:' + pctColor + ';">' + pctSign + pct24.toFixed(2) + '%</span>';
    priceTag.style.display = 'block';

    // 余额法币估值
    if (cachedTotalSats !== null) {
      var balScash = Number(cachedTotalSats) / 1e8;
      var fiatVal = balScash * priceUsd;
      var fiatEl = document.getElementById('balanceFiat');
      fiatEl.textContent = '\u2248 $' + fiatVal.toFixed(2) + ' USD';
      fiatEl.style.display = 'block';
    }

    // 图表右上角当前价格
    document.getElementById('chartCurrentPrice').textContent = '$' + priceUsd.toFixed(6);

    // 7日走势图
    var chartData = pd.priceChart;
    if (chartData && chartData.length > 1 && typeof LightweightCharts !== 'undefined') {
      // 去重：每30分钟只保留第一个数据点
      var seen = {};
      var deduped = [];
      for (var ci = 0; ci < chartData.length; ci++) {
        var ts = chartData[ci].timestamp;
        var key = ts.slice(0, 16);
        if (!seen[key]) {
          seen[key] = true;
          deduped.push(chartData[ci]);
        }
      }

      var pct7 = parseFloat(pd.price.changePercent7d || 0);
      var sign7 = pct7 >= 0 ? '+' : '';
      var color7 = pct7 >= 0 ? '#2f7a42' : '#c0392b';
      document.getElementById('chartPriceChange').innerHTML = '<span style="color:' + color7 + ';">7d ' + sign7 + pct7.toFixed(2) + '%</span>';

      document.getElementById('priceChartCard').style.display = 'block';
      requestAnimationFrame(function () {
        renderLWChart(deduped, priceUsd);
      });
    }
  }

  function renderLWChart(data, currentPrice) {
    var container = document.getElementById('priceChartContainer');
    if (!container) return;
    var cw = container.clientWidth;
    if (cw <= 0) return;

    // 清理旧图表
    if (lwChart) {
      lwChart.remove();
      lwChart = null;
      lwSeries = null;
    }

    var isUp = parseFloat(data[data.length - 1].price) >= parseFloat(data[0].price);
    var lineColor = isUp ? '#2f7a42' : '#c0392b';
    var topColor = isUp ? 'rgba(47,122,66,0.28)' : 'rgba(192,57,43,0.20)';
    var bottomColor = isUp ? 'rgba(47,122,66,0.02)' : 'rgba(192,57,43,0.02)';

    lwChart = LightweightCharts.createChart(container, {
      width: cw,
      height: 200,
      layout: {
        background: { type: 'solid', color: 'transparent' },
        textColor: '#999',
        fontSize: 11,
      },
      grid: {
        vertLines: { visible: false },
        horzLines: { color: '#f0f0f0', style: 2 },
      },
      crosshair: {
        mode: LightweightCharts.CrosshairMode.Magnet,
        vertLine: { width: 1, color: 'rgba(47,122,66,0.3)', style: 0, labelVisible: false },
        horzLine: { visible: false, labelVisible: false },
      },
      timeScale: {
        borderVisible: false,
        timeVisible: true,
        secondsVisible: false,
        fixLeftEdge: true,
        fixRightEdge: true,
      },
      rightPriceScale: {
        borderVisible: false,
        scaleMargins: { top: 0.1, bottom: 0.05 },
      },
      handleScroll: { vertTouchDrag: false },
      handleScale: { axisPressedMouseMove: false, pinch: false, mouseWheel: false },
    });

    lwSeries = lwChart.addAreaSeries({
      lineColor: lineColor,
      topColor: topColor,
      bottomColor: bottomColor,
      lineWidth: 2,
      crosshairMarkerVisible: true,
      crosshairMarkerRadius: 4,
      crosshairMarkerBorderColor: '#fff',
      crosshairMarkerBackgroundColor: lineColor,
      priceFormat: { type: 'price', precision: 6, minMove: 0.000001 },
    });

    var seriesData = data.map(function (d) {
      return {
        time: Math.floor(new Date(d.timestamp).getTime() / 1000),
        value: parseFloat(d.price),
      };
    });
    lwSeries.setData(seriesData);
    lwChart.timeScale().fitContent();

    // Crosshair tooltip
    var crosshairEl = document.getElementById('chartCrosshairPrice');
    var currentPriceEl = document.getElementById('chartCurrentPrice');
    lwChart.subscribeCrosshairMove(function (param) {
      if (!param || !param.time || !param.seriesData || !param.seriesData.size) {
        crosshairEl.textContent = '';
        currentPriceEl.textContent = '$' + currentPrice.toFixed(6);
        return;
      }
      var val = param.seriesData.get(lwSeries);
      if (val && typeof val.value === 'number') {
        var t = new Date(param.time * 1000);
        var timeStr = (t.getMonth() + 1) + '/' + t.getDate() + ' ' + String(t.getHours()).padStart(2, '0') + ':' + String(t.getMinutes()).padStart(2, '0');
        currentPriceEl.textContent = '$' + val.value.toFixed(6);
        crosshairEl.textContent = timeStr;
      }
    });

    // 监听容器大小变化
    if (window.ResizeObserver) {
      new ResizeObserver(function () {
        if (lwChart) {
          lwChart.applyOptions({ width: container.clientWidth });
        }
      }).observe(container);
    }
  }

  loadHome();

  // 价格加载
  if (window.SCASH.priceLoading) {
    window.SCASH.priceLoading.then(function () { updatePriceDisplay(); });
  }

  /* QR scan from homepage */
  var tg = window.SCASH && window.SCASH.TG;
  if (tg) {
    tg.onEvent('qrTextReceived', function (obj) {
      tg.closeScanQrPopup();
      var raw = (obj.data || '').trim();
      var address = raw;
      /* strip scash: prefix if present */
      if (address.indexOf('scash:') === 0) {
        address = address.slice(6);
      }
      var bech32Prefix = (window.SCASH && window.SCASH.NETWORK && window.SCASH.NETWORK.bech32) || 'bcrt';
      if (address.indexOf(bech32Prefix + '1') === 0) {
        location.href = '/wallet/send?address=' + encodeURIComponent(address);
      } else {
        tg.showAlert('不支持的地址格式');
      }
    });

    document.getElementById('scanQrHomeBtn').addEventListener('click', function () {
      tg.showScanQrPopup({ text: '扫描收款地址二维码' });
    });
  }
</script>