<div class="card">
  <div class="info">
    只需设置一个密码，系统会自动生成助记词并创建钱包。助记词加密后仅保存在你的账号下，换设备可恢复。
  </div>

  <div class="label">设置钱包密码</div>
  <div class="input-wrap" style="margin-bottom: 12px;">
    <input id="password" type="password" placeholder="请输入密码（不少于8位）" autocomplete="off" />
  </div>
  <div class="input-wrap" style="margin-bottom: 16px;">
    <input id="confirm" type="password" placeholder="再次输入密码确认" autocomplete="off" />
  </div>

  <button id="submitBtn" class="btn btn-brand">创建钱包</button>
  <div id="errorMsg" class="error" style="display:none; margin-top:10px;"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bitcoinjs-lib@6.1.5/dist/bitcoinjs-lib.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bip39@3.1.0/dist/bip39.min.js"></script>
<script>
  function setLoading(on) {
    var btn = document.getElementById('submitBtn');
    if (on) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span>生成中…';
    } else {
      btn.disabled = false;
      btn.textContent = '创建钱包';
    }
  }

  function showError(msg) {
    var el = document.getElementById('errorMsg');
    el.textContent = msg;
    el.style.display = 'block';
  }

  function deriveScashAddress(mnemonic) {
    var seed = bitcoinjs.bip39.mnemonicToSeed(mnemonic);
    var root = bitcoinjs.bip32.fromSeed(seed);
    var child = root.derivePath("m/84'/0'/0'/0/0");
    return bitcoinjs.payments.p2wpkh({ pubkey: child.publicKey, network: bitcoinjs.networks.bitcoin }).address;
  }

  async function encryptMnemonic(mnemonic, password) {
    var salt = crypto.getRandomValues(new Uint8Array(16));
    var iv = crypto.getRandomValues(new Uint8Array(12));
    var keyMaterial = await crypto.subtle.importKey('raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveBits']);
    var key = await crypto.subtle.deriveBits({ name: 'PBKDF2', salt: salt, iterations: 100000, hash: 'SHA-256' }, keyMaterial, 256);
    var aesKey = await crypto.subtle.importKey('raw', key, 'AES-GCM', false, ['encrypt']);
    var ciphertext = await crypto.subtle.encrypt({ name: 'AES-GCM', iv: iv, tagLength: 128 }, aesKey, new TextEncoder().encode(mnemonic));
    function toHex(arr) { return Array.from(new Uint8Array(arr)).map(function (b) { return b.toString(16).padStart(2, '0'); }).join(''); }
    return { salt: toHex(salt), iv: toHex(iv), ciphertext: toHex(ciphertext) };
  }

  document.getElementById('submitBtn').addEventListener('click', async function () {
    var pw = document.getElementById('password').value.trim();
    var cw = document.getElementById('confirm').value.trim();
    showError('');
    if (pw.length < 8) { showError('密码长度不能少于8位'); return; }
    if (pw !== cw) { showError('两次密码输入不一致'); return; }
    setLoading(true);
    try {
      var mnemonic = bitcoinjs.bip39.generateMnemonic(128);
      var address = deriveScashAddress(mnemonic);
      var enc = await encryptMnemonic(mnemonic, pw);
      await window.SCASH.request('/api/wallet/create', {
        method: 'POST',
        body: JSON.stringify({
          address: address,
          encryptedMnemonic: enc.ciphertext,
          salt: enc.salt,
          iv: enc.iv,
          authTag: enc.ciphertext.slice(0, 32),
        }),
      });
      if (window.SCASH.TG) window.SCASH.TG.close();
    } catch (e) {
      showError(e.message);
      setLoading(false);
    }
  });
</script>