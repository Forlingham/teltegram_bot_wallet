<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= pageTitle %></title>
    <style>
      body { margin: 0; font-family: "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif; background: #f5f8f3; color: #1f2a1f; }
      .wrap { max-width: 760px; margin: 0 auto; padding: 20px 16px 40px; }
      .card { background: #fff; border: 1px solid #d9e3d7; border-radius: 14px; padding: 18px; margin-bottom: 14px; }
      h1 { margin: 0 0 10px; }
      .sub { color: #5b665c; margin: 0 0 14px; }
      .row { margin-bottom: 12px; }
      label { display: block; margin-bottom: 6px; font-size: 13px; color: #586258; }
      input { width: 100%; padding: 10px; border: 1px solid #cad7c8; border-radius: 10px; }
      button { border: 0; background: #2f7a42; color: white; border-radius: 10px; padding: 10px 14px; font-weight: 600; cursor: pointer; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>导入钱包</h1>
        <p class="sub">请在前端完成助记词解码与加密后再提交，后端不接触明文助记词。</p>
      </div>

      <div class="card">
        <div class="row"><label>钱包地址</label><input id="address" placeholder="scash1..." /></div>
        <div class="row"><label>加密助记词</label><input id="encryptedMnemonic" placeholder="ciphertext" /></div>
        <div class="row"><label>Salt</label><input id="salt" placeholder="salt" /></div>
        <div class="row"><label>IV</label><input id="iv" placeholder="iv" /></div>
        <div class="row"><label>AuthTag</label><input id="authTag" placeholder="authTag" /></div>
        <button id="submitBtn">提交导入</button>
      </div>
    </div>

    <script>
      (function () {
        const enabled = new URL(window.location.href).searchParams.get('debug') === '1' ||
          localStorage.getItem('DEBUG_CONSOLE') === '1';
        if (!enabled) return;
        const script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/eruda';
        script.onload = function () { window.eruda && window.eruda.init(); };
        document.head.appendChild(script);
      })();
    </script>
    <script>
      const SESSION_KEY = 'SCASH_SESSION_TOKEN';
      function token() { return localStorage.getItem(SESSION_KEY) || ''; }
      function val(id) { return document.getElementById(id).value.trim(); }

      async function request(path, options = {}) {
        const res = await fetch(path, {
          ...options,
          headers: {
            'Content-Type': 'application/json',
            'x-session-token': token(),
            ...(options.headers || {}),
          },
        });
        const json = await res.json();
        if (!res.ok || !json.success) throw new Error((json.error && json.error.message) || '请求失败');
        return json.data;
      }

      document.getElementById('submitBtn').addEventListener('click', async () => {
        try {
          await request('/api/wallet/import', {
            method: 'POST',
            body: JSON.stringify({
              address: val('address'),
              encryptedMnemonic: val('encryptedMnemonic'),
              salt: val('salt'),
              iv: val('iv'),
              authTag: val('authTag'),
            }),
          });
          alert('钱包导入成功');
          location.href = '/wallet';
        } catch (e) {
          alert(e.message);
        }
      });
    </script>
  </body>
  </html>
