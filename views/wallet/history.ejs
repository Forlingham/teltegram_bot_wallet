<div class="card">
  <div class="label">交易记录</div>
</div>

<div id="txList">
  <div style="text-align:center; padding:24px; color:var(--muted); font-size:13px;">加载中…</div>
</div>

<script>
  function explorerBaseUrl() {
    return (window.SCASH && window.SCASH.ENV) === 'production'
      ? 'https://explorer.scash.network'
      : 'http://38.76.197.97:3001';
  }

  function txExplorerUrl(txid) {
    return explorerBaseUrl().replace(/\/$/, '') + '/tx/' + encodeURIComponent(txid);
  }

  function formatLocalTime(iso) {
    if (!iso) return '-';
    var d = new Date(iso);
    if (isNaN(d.getTime())) return iso;
    return d.toLocaleString('zh-CN', { hour12: false });
  }

  function formatTxid(txid) {
    if (!txid) return '-';
    if (txid.length <= 20) return txid;
    return txid.slice(0, 10) + '...' + txid.slice(-10);
  }

  async function loadHistory() {
    try {
      var home = await window.SCASH.request('/api/wallet/home');
      var data = await window.SCASH.request('/api/wallet/history');
      var el = document.getElementById('txList');
      if (!data.transactions || data.transactions.length === 0) {
        var emptyText = home.hasWallet ? '暂无交易记录' : '暂无记录（未创建钱包时仅展示抢到的红包）';
        el.innerHTML = '<div style="text-align:center; padding:24px; color:var(--muted); font-size:13px;">' + emptyText + '</div>';
        return;
      }
      el.innerHTML = data.transactions.map(function (tx) {
        var dir = tx.direction || 'unknown';
        var dirLabel = dir === 'in' ? '转入' : (dir === 'out' ? '转出' : '未知');
        var dirColor = dir === 'in' ? 'var(--brand)' : (dir === 'out' ? '#c0392b' : 'var(--muted)');
        var rpTypeMap = { CREATE: '红包创建', CLAIM: '红包领取', REFUND: '红包退款' };
        var badge = (tx.kind === 'redpacket' && tx.redpacketType) ? (rpTypeMap[tx.redpacketType] || '红包交易') : '链上交易';
        var badgeBg = tx.kind === 'redpacket' ? '#fff1df' : '#edf7ef';
        var badgeColor = tx.kind === 'redpacket' ? '#a95a08' : 'var(--brand)';
        var pending = tx.isUnconfirmed ? '（未确认）' : '';
        var txLine = tx.txid && tx.txid.indexOf('claim-') !== 0
          ? '<a href="' + txExplorerUrl(tx.txid) + '" target="_blank" rel="noopener noreferrer" class="mono" style="font-size:12px; color:var(--brand); text-decoration:none;">' + formatTxid(tx.txid) + '</a>'
          : '<span class="mono" style="font-size:12px; color:var(--muted);">' + formatTxid(tx.txid || '') + '</span>';

        var redpacketExtra = '';
        if (tx.redpacketType === 'CREATE' && tx.redpacketInfo) {
          var info = tx.redpacketInfo;
          var statusMap = {
            ACTIVE: { text: '进行中', bg: '#edf7ef', color: 'var(--brand)', border: '#d7eadb' },
            COMPLETED: { text: '已抢完', bg: '#fff1df', color: '#a95a08', border: '#f1ce9c' },
            EXPIRED: { text: '已过期', bg: '#f7f0f0', color: '#9b1c1c', border: '#e5caca' },
            REFUNDED: { text: '已退款', bg: '#eef2ff', color: '#3730a3', border: '#c7d2fe' },
          };
          var s = statusMap[info.status] || { text: '已结束', bg: '#f3f4f6', color: '#4b5563', border: '#d1d5db' };
          var shareBtn = '';
          if (info.canShare && info.shareUrl) {
            shareBtn = '<button class="btn btn-soft rp-share-btn" data-url="' + info.shareUrl + '" style="padding:6px 10px; font-size:12px;">再次分享</button>';
          }
          redpacketExtra =
            '<div style="margin-top:8px; padding:8px; border-radius:10px; background:' + s.bg + '; border:1px dashed ' + s.border + ';">' +
              '<div style="margin-bottom:6px;"><span style="display:inline-block; padding:2px 8px; border-radius:999px; background:#fff; color:' + s.color + '; border:1px solid ' + s.border + '; font-size:12px; font-weight:700;">' + s.text + '</span></div>' +
              '<div class="label" style="margin:0 0 4px;">过期时间：' + formatLocalTime(info.expiresAt) + '</div>' +
              '<div class="label" style="margin:0 0 4px;">领取人数：' + info.claimedCount + '</div>' +
              '<div class="label" style="margin:0 0 4px;">剩余个数：' + info.remainingCount + '</div>' +
              '<div class="label" style="margin:0 0 6px;">剩余金额：' + info.remainingAmount + ' SCASH</div>' +
              shareBtn +
            '</div>';
        }

        return '<div class="card" style="margin-bottom:8px;">' +
          '<div class="row">' +
            '<div style="font-weight:700; color:' + dirColor + ';">' + dirLabel + '</div>' +
            '<div style="font-weight:700;">' + tx.amount + ' SCASH</div>' +
          '</div>' +
          '<div style="margin-top:6px;">' +
            '<span style="display:inline-block; padding:2px 8px; border-radius:999px; background:' + badgeBg + '; color:' + badgeColor + '; font-size:12px; font-weight:700;">' + badge + pending + '</span>' +
          '</div>' +
          '<div class="label" style="margin-top:8px;">TxHash: ' + txLine + '</div>' +
          redpacketExtra +
          '<div class="label" style="margin-top:2px; font-size:11px; color:var(--muted);">' + (tx.time || tx.txid || '') + '</div>' +
        '</div>';
      }).join('');

      el.querySelectorAll('.rp-share-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var shareUrl = btn.getAttribute('data-url') || '';
          if (!shareUrl) return;
          var tg = window.SCASH && window.SCASH.TG;
          var shareText = '我发了一个SCASH红包，快来领取！';
          var shareIntent = 'https://t.me/share/url?url=' + encodeURIComponent(shareUrl) + '&text=' + encodeURIComponent(shareText);
          if (tg && tg.openTelegramLink) tg.openTelegramLink(shareIntent);
          else location.href = shareIntent;
        });
      });
    } catch (e) {
      document.getElementById('txList').innerHTML = '<div style="text-align:center; padding:24px; color:#c0392b; font-size:13px;">加载失败</div>';
    }
  }

  loadHistory();
</script>
