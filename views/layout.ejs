<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "secondary-dim": "#42525a",
            "on-secondary-container": "#44545c",
            "secondary": "#4e5e66",
            "on-primary": "#ffeefd",
            "on-primary-fixed": "#110018",
            "on-primary-container": "#47005a",
            "on-tertiary-container": "#005f51",
            "surface": "#f5f7f9",
            "surface-container-highest": "#d9dde0",
            "on-surface": "#2c2f31",
            "surface-container-lowest": "#ffffff",
            "tertiary": "#006859",
            "outline": "#747779",
            "inverse-on-surface": "#9a9d9f",
            "on-error": "#ffefef",
            "primary-container": "#e67aff",
            "error-container": "#f74b6d",
            "surface-dim": "#d0d5d8",
            "on-background": "#2c2f31",
            "secondary-fixed-dim": "#c6d7e1",
            "on-secondary-fixed-variant": "#4e5e66",
            "on-tertiary": "#c2ffef",
            "surface-container": "#e5e9eb",
            "secondary-fixed": "#d4e5ef",
            "primary-fixed": "#e67aff",
            "tertiary-dim": "#005a4d",
            "primary-fixed-dim": "#d76df1",
            "error-dim": "#a70138",
            "outline-variant": "#abadaf",
            "on-tertiary-fixed-variant": "#006a5a",
            "primary-dim": "#8315a0",
            "surface-tint": "#9128ad",
            "tertiary-fixed-dim": "#5aeed2",
            "inverse-primary": "#e67aff",
            "tertiary-fixed": "#6bfde0",
            "on-tertiary-fixed": "#004a3f",
            "on-secondary-fixed": "#324249",
            "error": "#b41340",
            "secondary-container": "#d4e5ef",
            "surface-container-high": "#dfe3e6",
            "surface-bright": "#f5f7f9",
            "on-primary-fixed-variant": "#56006b",
            "primary": "#9128ad",
            "surface-variant": "#d9dde0",
            "inverse-surface": "#0b0f10",
            "on-surface-variant": "#595c5e",
            "on-secondary": "#e4f5ff",
            "tertiary-container": "#6bfde0",
            "surface-container-low": "#eef1f3",
            "on-error-container": "#510017",
            "background": "#f5f7f9"
          },
          borderRadius: {
            DEFAULT: "1rem",
            lg: "2rem",
            xl: "3rem",
            full: "9999px"
          },
          fontFamily: {
            headline: ["Plus Jakarta Sans"],
            body: ["Manrope"],
            label: ["Manrope"]
          }
        },
      },
    }
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    body { font-family: 'Manrope', sans-serif; }
    h1, h2, h3, .font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }
    .glass-header { background: rgba(245, 247, 249, 0.8); backdrop-filter: blur(20px); }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    :root {
      --bg: #f4f8f1;
      --panel: #ffffff;
      --text: #1e2a1e;
      --muted: #5e695e;
      --line: #d6e1d2;
      --brand: #2f7a42;
      --warn-bg: #fff1df;
      --warn-text: #a95a08;
      --warn-border: #f1ce9c;
    }
    * { box-sizing: border-box; }
    body { margin: 0; background: var(--bg); color: var(--text); }
    .app { max-width: 860px; margin: 0 auto; padding: 16px 16px <%= (typeof hideBottomNav !== 'undefined' && hideBottomNav) ? 16 : 88 %>px; }
    .card { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 14px; margin-bottom: 12px; }
    .label { color: var(--muted); font-size: 13px; margin-bottom: 6px; }
    .value { font-size: 18px; font-weight: 700; margin-top: 6px; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; word-break: break-all; font-size: 13px; }
    .warn { background: var(--warn-bg); border-color: #f1ce9c; }
    .warn-title { margin: 0 0 8px; color: var(--warn-text); font-weight: 700; }
    .warn-desc { margin: 0 0 12px; font-size: 14px; line-height: 1.5; }
    .row { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
    .btn { border: none; border-radius: 10px; padding: 10px 12px; font-weight: 600; cursor: pointer; }
    .btn-brand { background: var(--brand); color: #fff; }
    .btn-soft { background: #e6f3ea; color: var(--brand); }
    .btn-brand:disabled { opacity: 0.6; cursor: not-allowed; }
    .actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .quick-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 8px; }
    .quick-link { display: block; text-align: center; text-decoration: none; color: var(--brand); background: #edf7ef; border: 1px solid #d7eadb; border-radius: 10px; padding: 10px 8px; font-weight: 600; font-size: 14px; }
    input, textarea, .input-wrap { width: 100%; padding: 12px; border: 1px solid var(--line); border-radius: 10px; font-size: 16px; background: #fafefa; margin-bottom: 12px; }
    input:focus, textarea:focus { outline: none; border-color: var(--brand); }
    .info { font-size: 13px; color: var(--muted); margin-bottom: 16px; line-height: 1.5; }
    .error { color: #c0392b; font-size: 13px; margin-top: 6px; }
    pre { background: #f4f7f2; border-radius: 10px; padding: 12px; font-size: 12px; overflow-x: auto; word-break: break-all; margin: 0; font-family: ui-monospace, monospace; }
    .spinner { display: inline-block; width: 16px; height: 16px; border: 2px solid #fff; border-top-color: transparent; border-radius: 50%; animation: spin 0.7s linear infinite; vertical-align: middle; margin-right: 6px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes spin-fast { to { transform: rotate(360deg); } }
    .spin-anim { animation: spin-fast 0.8s linear infinite; }
    .spinner-sm { display: inline-block; width: 18px; height: 18px; border: 2px solid currentColor; border-top-color: transparent; border-radius: 50%; opacity: 0.7; }
  </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col pb-24 overflow-x-hidden">
  <%- include('partials/header') %>
  <main class="app flex-1 px-4 space-y-6 max-w-lg mx-auto w-full">
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
      window.SCASH = {
        SESSION_KEY: 'SCASH_SESSION_TOKEN',
        TG_USER_KEY: 'SCASH_TG_USER_ID',
        TG: window.Telegram && window.Telegram.WebApp,
        ENV: '<%= appEnv || "development" %>',
        REQUIRE_FULL_WALLET: <%= (typeof requireFullWallet !== 'undefined' && requireFullWallet) ? 'true' : 'false' %>,
        REQUIRE_ANY_WALLET: <%= (typeof requireAnyWallet !== 'undefined' && requireAnyWallet) ? 'true' : 'false' %>,
        NETWORK: {
          bech32: '<%= (scashNetwork && scashNetwork.bech32) || "bcrt" %>',
          pubKeyHash: <%= (scashNetwork && scashNetwork.pubKeyHash) || 60 %>,
          scriptHash: <%= (scashNetwork && scashNetwork.scriptHash) || 125 %>,
        },
        POOL_ADDRESS: '<%= poolAddress || "" %>',
        getToken: function () { return localStorage.getItem(this.SESSION_KEY) || ''; },
        getTokenForUser: function (tgUserId) {
          if (!tgUserId) return null;
          return localStorage.getItem('SCASH_TOKEN_' + tgUserId) || null;
        },
        setTokenForUser: function (tgUserId, token) {
          localStorage.setItem('SCASH_TOKEN_' + tgUserId, token);
          localStorage.setItem(this.SESSION_KEY, token);
          localStorage.setItem(this.TG_USER_KEY, tgUserId);
        },
        parseTgUserIdFromInitData: function (initDataStr) {
          if (!initDataStr) return '';
          try {
            var params = new URLSearchParams(initDataStr);
            var userJson = params.get('user');
            if (userJson) {
              var user = JSON.parse(decodeURIComponent(userJson));
              if (user && user.id) return String(user.id);
            }
          } catch (e) {}
          return '';
        },
        getCurrentTgUserId: function () {
          var tg = this.TG;
          if (tg && tg.initDataUnsafe && tg.initDataUnsafe.user) {
            return String(tg.initDataUnsafe.user.id);
          }
          var initData = this.readInitData();
          return this.parseTgUserIdFromInitData(initData);
        },
        readInitData: function () {
          var tg = this.TG;
          if (tg) { tg.ready(); if (tg.initData) return tg.initData; }
          var params = new URL(location.href).searchParams;
          return params.get('tgWebAppData') || '';
        },
        ensureSession: async function () {
          var currentTgUserId = this.getCurrentTgUserId();

          if (currentTgUserId) {
            var userToken = this.getTokenForUser(currentTgUserId);
            if (userToken) {
              localStorage.setItem(this.SESSION_KEY, userToken);
              localStorage.setItem(this.TG_USER_KEY, currentTgUserId);
              return userToken;
            }
          } else {
            var existing = this.getToken();
            if (existing) return existing;
          }

          var initData = this.readInitData();
          if (!initData) throw new Error('会话已过期，请关闭并重新打开 Mini App');
          var res = await fetch('/api/auth/telegram/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ initData: initData }),
          });
          var json = await res.json();
          if (!res.ok || !json.success) {
            var errMsg = (json.error && json.error.message) || '';
            if (errMsg.toLowerCase().indexOf('replay') !== -1 || errMsg.toLowerCase().indexOf('expired') !== -1) {
              throw new Error('会话已过期，请关闭并重新打开 Mini App');
            }
            throw new Error(errMsg || '登录失败');
          }
          var newToken = json.data.sessionToken;
          if (currentTgUserId) {
            this.setTokenForUser(currentTgUserId, newToken);
          } else {
            localStorage.setItem(this.SESSION_KEY, newToken);
          }
          return newToken;
        },
        request: async function (path, options) {
          var token = await this.ensureSession();
          var mergedOptions = Object.assign({}, options || {}, {
            headers: Object.assign({ 'Content-Type': 'application/json', 'x-session-token': token }, (options || {}).headers || {}),
          });
          var res = await fetch(path, mergedOptions);
          if (res.status === 401) {
            var uid = this.getCurrentTgUserId();
            localStorage.removeItem(this.SESSION_KEY);
            localStorage.removeItem(this.TG_USER_KEY);
            if (uid) localStorage.removeItem('SCASH_TOKEN_' + uid);
            token = await this.ensureSession();
            mergedOptions.headers['x-session-token'] = token;
            res = await fetch(path, mergedOptions);
          }
          var json = await res.json();
          if (!res.ok || !json.success) throw new Error((json.error && json.error.message) || '请求失败');
          return json.data;
        },
        checkWalletPermission: async function () {
          if (!this.REQUIRE_FULL_WALLET && !this.REQUIRE_ANY_WALLET) return;
          try {
            var home = await this.request('/api/wallet/home');
            
            if (!home.hasWallet) {
              alert('该操作需要先创建钱包');
              location.replace('/wallet');
              return;
            }
            
            if (this.REQUIRE_FULL_WALLET && home.isWatchOnly) {
              alert('观察钱包仅支持接收，无法进行发送或签名操作');
              location.replace('/wallet');
              return;
            }
          } catch(e) {
            location.replace('/wallet');
          }
        }
      };

      window.SCASH.checkWalletPermission();

      window.SCASH.priceData = null;
      window.SCASH.priceLoading = (function () {
        var CACHE_KEY = 'SCASH_PRICE_CACHE';
        var CACHE_TIME_KEY = 'SCASH_PRICE_CACHE_TIME';
        var CACHE_TTL = 30 * 60 * 1000;
        
        try {
          var cachedTime = localStorage.getItem(CACHE_TIME_KEY);
          if (cachedTime && Date.now() - parseInt(cachedTime, 10) < CACHE_TTL) {
            var cachedData = localStorage.getItem(CACHE_KEY);
            if (cachedData) {
              var parsed = JSON.parse(cachedData);
              window.SCASH.priceData = parsed;
              return Promise.resolve(parsed);
            }
          }
        } catch (e) {}

        return fetch('https://explorer.scash.network/api/explorer/home/overview')
          .then(function (r) { return r.json(); })
          .then(function (json) {
            if (json && json.price) {
              window.SCASH.priceData = json;
              try {
                localStorage.setItem(CACHE_KEY, JSON.stringify(json));
                localStorage.setItem(CACHE_TIME_KEY, Date.now().toString());
              } catch (e) {}
            }
            return window.SCASH.priceData;
          })
          .catch(function () {
            try {
              var staleData = localStorage.getItem(CACHE_KEY);
              if (staleData) {
                var parsedStale = JSON.parse(staleData);
                window.SCASH.priceData = parsedStale;
                return parsedStale;
              }
            } catch (e) {}
            return null;
          });
      })();

      window.SCASH.IS_PRIMARY_PAGE = <%= (typeof backAsClose !== 'undefined' && backAsClose) ? 'true' : 'false' %>;

      (function () {
        var tg = window.SCASH.TG;
        if (!tg) return;

        if (window.SCASH.IS_PRIMARY_PAGE) {
          tg.BackButton.hide();
        } else {
          tg.BackButton.show();
          tg.onEvent('backButtonClicked', function () { history.back(); });
        }
      })();
    </script>
    <%- body %>
  </main>
  <% if (!(typeof hideBottomNav !== 'undefined' && hideBottomNav)) { %>
    <%- include('partials/bottom-nav') %>
  <% } %>
  <script>
    (function () {
      var params = new URL(location.href).searchParams;
      var debugParam = params.get('debug');
      if (debugParam === '1') localStorage.setItem('DEBUG_CONSOLE', '1');
      if (debugParam === '0') localStorage.removeItem('DEBUG_CONSOLE');

      var enabled = localStorage.getItem('DEBUG_CONSOLE') === '1';
      if (!enabled) return;

      document.querySelectorAll('a[href^="/"]').forEach(function (a) {
        try {
          var u = new URL(a.href, location.origin);
          u.searchParams.set('debug', '1');
          a.href = u.pathname + u.search + u.hash;
        } catch (_) {}
      });

      if (window.eruda) {
        window.eruda.show();
        return;
      }

      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/eruda';
      s.onload = function () { if (window.eruda) window.eruda.init(); };
      document.head.appendChild(s);
    })();
  </script>
</body>
</html>